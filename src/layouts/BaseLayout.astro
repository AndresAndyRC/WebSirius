---
/**
 * BaseLayout.astro — Root HTML shell: fonts, styles, SEO head, TopBar, Header, Footer
 */
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MetaTags from '@components/MetaTags.astro';
import GoogleAnalytics from '@components/GoogleAnalytics.astro';
import LightCursor from '@components/LightCursor.tsx';
import CartDrawer from '@components/cart/CartDrawer.tsx';
import type { Props as MetaProps } from '@components/MetaTags.astro';

import '@styles/global.css';

interface Props extends MetaProps {}

const props = Astro.props;
---

<!doctype html>
<html lang="es-CO">
  <head>
    <MetaTags {...props} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <!-- Google Analytics 4 — solo production -->
    <GoogleAnalytics />
  </head>

  <body>
    <!-- Skip to content for keyboard users -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <!-- Global cursor light glow (only desktop/hover devices) -->
    <LightCursor client:only="react" />

    <!-- Global Cart Drawer -->
    <CartDrawer client:load />
  </body>
</html>

<style is:global>
.skip-link {
  position: absolute;
  top: -100%;
  left: var(--space-4);
  z-index: 9999;
  background: var(--color-brand-primary);
  color: var(--color-text-inverse);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-md);
  font-weight: var(--fw-semibold);
  font-size: var(--text-sm);
  transition: top var(--duration-fast);
}
.skip-link:focus {
  top: var(--space-2);
}
.material-symbols-outlined {
  vertical-align: middle;
  line-height: inherit;
  font-size: 1.2em;
}
</style>
