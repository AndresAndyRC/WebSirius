---
/**
 * src/pages/contacto/index.astro
 * Premium reinvention of siriuscol.com/pages/contact
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LightBeams from '@components/LightBeams.astro';
import ContactForm from '@components/contact/ContactForm.tsx';

const CONTACT_CHANNELS = [
  {
    icon: '📞',
    label: 'Llámanos',
    value: '+57 316 307 0062',
    href: 'tel:+573163070062',
    desc: 'Lunes a viernes · 8am–6pm',
    color: '#22c55e',
    bg: 'rgba(34,197,94,0.07)',
    border: 'rgba(34,197,94,0.20)',
  },
  {
    icon: '💬',
    label: 'WhatsApp',
    value: 'Iniciar chat',
    href: 'https://wa.me/573163070062?text=Hola%2C%20quiero%20información%20sobre%20sus%20productos%20SIRIUS',
    desc: 'Respuesta en menos de 1 hora',
    color: '#25D366',
    bg: 'rgba(37,211,102,0.07)',
    border: 'rgba(37,211,102,0.25)',
    featured: true,
  },
  {
    icon: '📧',
    label: 'Correo electrónico',
    value: 'gerencia@steelplanet.com.co',
    href: 'mailto:gerencia@steelplanet.com.co',
    desc: 'Respuesta en 24–48 horas hábiles',
    color: '#F5A623',
    bg: 'rgba(245,166,35,0.07)',
    border: 'rgba(245,166,35,0.20)',
  },
  {
    icon: '📍',
    label: 'Visítanos',
    value: 'Calle 22 # 49-36',
    href: 'https://maps.google.com/?q=Calle+22+%2349-36+Fusagasugá+Cundinamarca+Colombia',
    desc: 'Fusagasugá, Cundinamarca · Colombia',
    color: '#60A5FA',
    bg: 'rgba(96,165,250,0.07)',
    border: 'rgba(96,165,250,0.20)',
  },
];

const SOCIAL_LINKS = [
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=100090449014923',
    color: '#1877F2',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/siriuscol_com',
    color: '#E1306C',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  },
  {
    name: 'TikTok',
    href: 'https://www.tiktok.com/@siriushopm',
    color: '#EE1D52',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.39a8.19 8.19 0 004.78 1.52V6.48a4.85 4.85 0 01-1.01-.21z"/></svg>`,
  },
];

const FAQS = [
  {
    q: '¿Cuánto tarda en llegar mi pedido?',
    a: 'Envíos a Bogotá en 1–2 días hábiles. Resto del país entre 3–5 días hábiles. Consulta disponibilidad en tu zona.',
  },
  {
    q: '¿Hacen instalaciones eléctricas?',
    a: 'No ofrecemos instalaciones directamente, pero podemos recomendarte técnicos certificados aliados en Fusagasugá y Bogotá.',
  },
  {
    q: '¿Tienen asesoría para proyectos grandes?',
    a: 'Sí. Para proyectos comerciales, industriales o desarrollos inmobiliarios ofrecemos asesoría técnica gratuita. Escríbenos por WhatsApp.',
  },
  {
    q: '¿Cuál es la política de garantía?',
    a: 'Todos los productos LED tienen garantía de 2 años contra defectos de fabricación. Los accesorios eléctricos varían según fabricante.',
  },
];
---

<BaseLayout
  title="Contáctanos — SIRIUS Iluminación LED Colombia"
  description="Resuelve tus dudas, recibe asesoría personalizada o realiza tu pedido. Estamos en Fusagasugá, Cundinamarca. WhatsApp, teléfono y correo disponibles."
  canonical="https://siriuscol.com/pages/contact"
  ogType="website"
>
  <!-- ══════════════════════════════════════════
       HERO
       ══════════════════════════════════════════ -->
  <section class="ct-hero">
    <LightBeams variant="subtle" />
    <div class="ct-hero__glow ct-hero__glow--amber" aria-hidden="true"></div>
    <div class="ct-hero__glow ct-hero__glow--blue"  aria-hidden="true"></div>

    <div class="container ct-hero__inner">
      <nav aria-label="Ruta de navegación" class="ct-breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Contacto</span>
      </nav>

      <div class="ct-hero__badge">
        <span class="ct-online-dot" aria-hidden="true"></span>
        Equipo disponible ahora
      </div>

      <h1 class="ct-hero__title font-display">
        Hablemos de tu<br />
        <span class="gradient-text">proyecto de iluminación</span>
      </h1>
      <p class="ct-hero__desc">
        Ya sea que tengas una duda antes de comprar, necesites asesoría técnica
        para un proyecto o quieras hablar de distribución — estamos aquí.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       CONTACT CHANNELS
       ══════════════════════════════════════════ -->
  <section class="ct-channels section--sm" aria-labelledby="channels-heading">
    <div class="container">
      <h2 class="visually-hidden" id="channels-heading">Canales de contacto</h2>
      <div class="ct-channels__grid">
        {CONTACT_CHANNELS.map(ch => (
          <a
            href={ch.href}
            target={ch.href.startsWith('http') ? '_blank' : undefined}
            rel={ch.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="ct-channel-card"
            style={`--ch-color:${ch.color};--ch-bg:${ch.bg};--ch-border:${ch.border}`}
            aria-label={`${ch.label}: ${ch.value}`}
          >
            {ch.featured && (
              <span class="ct-channel-badge">⭐ Más rápido</span>
            )}
            <span class="ct-channel-icon" aria-hidden="true">{ch.icon}</span>
            <div class="ct-channel-body">
              <p class="ct-channel-label">{ch.label}</p>
              <p class="ct-channel-value">{ch.value}</p>
              <p class="ct-channel-desc">{ch.desc}</p>
            </div>
            <svg class="ct-channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       MAIN: FORM + SIDEBAR
       ══════════════════════════════════════════ -->
  <section class="ct-main section" aria-labelledby="form-heading">
    <div class="container ct-main__inner">
      <!-- ── Contact Form ── -->
      <div class="ct-form-panel">
        <h2 class="ct-form-panel__title font-display" id="form-heading">
          Envíanos un mensaje
        </h2>
        <p class="ct-form-panel__sub">
          Completa el formulario y te respondemos en las próximas 24–48 horas hábiles.
        </p>
        <ContactForm client:load />
      </div>

      <!-- ── Sidebar ── -->
      <aside class="ct-sidebar" aria-label="Información adicional de contacto">
        <!-- Location card -->
        <div class="ct-sidebar-card ct-location">
          <div class="ct-location__map" aria-label="Mapa de ubicación" role="img">
            <!-- Decorative SVG map placeholder -->
            <svg viewBox="0 0 380 200" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block;" aria-hidden="true">
              <rect width="380" height="200" fill="#0e1520"/>
              <!-- Grid lines -->
              {Array.from({length: 8}).map((_, i) => (
                <line x1={i*50} y1="0" x2={i*50} y2="200" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              ))}
              {Array.from({length: 5}).map((_, i) => (
                <line x1="0" y1={i*50} x2="380" y2={i*50} stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              ))}
              <!-- "Roads" -->
              <rect x="0" y="88" width="380" height="8" rx="2" fill="rgba(255,255,255,0.06)"/>
              <rect x="175" y="0" width="8" height="200" rx="2" fill="rgba(255,255,255,0.06)"/>
              <rect x="60" y="50" width="160" height="5" rx="2" fill="rgba(255,255,255,0.04)"/>
              <rect x="230" y="120" width="120" height="5" rx="2" fill="rgba(255,255,255,0.04)"/>
              <!-- Location pin -->
              <circle cx="190" cy="100" r="28" fill="rgba(245,166,35,0.15)"/>
              <circle cx="190" cy="100" r="16" fill="rgba(245,166,35,0.30)"/>
              <circle cx="190" cy="100" r="7"  fill="#F5A623"/>
              <!-- Pin pulse rings -->
              <circle cx="190" cy="100" r="22" fill="none" stroke="rgba(245,166,35,0.40)" stroke-width="1.5"/>
              <circle cx="190" cy="100" r="33" fill="none" stroke="rgba(245,166,35,0.20)" stroke-width="1"/>
            </svg>
            <a
              href="https://maps.google.com/?q=Calle+22+%2349-36+Fusagasugá+Cundinamarca+Colombia"
              target="_blank"
              rel="noopener noreferrer"
              class="ct-location__open-maps btn btn--secondary"
              aria-label="Abrir en Google Maps"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Abrir en Maps
            </a>
          </div>
          <div class="ct-location__info">
            <p class="ct-location__address">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Calle 22 # 49-36, Fusagasugá
            </p>
            <p class="ct-location__region">Cundinamarca · Colombia</p>
          </div>
        </div>

        <!-- Hours card -->
        <div class="ct-sidebar-card">
          <h3 class="ct-sidebar-card__title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Horario de atención
          </h3>
          <ul class="ct-hours-list">
            <li><span>Lunes – Viernes</span><span class="ct-hours-time">8:00 am – 6:00 pm</span></li>
            <li><span>Sábado</span><span class="ct-hours-time">9:00 am – 2:00 pm</span></li>
            <li><span>Domingo</span><span class="ct-hours-time ct-hours-closed">Cerrado</span></li>
          </ul>
          <div class="ct-hours-note">
            <span class="ct-online-dot" aria-hidden="true"></span>
            WhatsApp activo fuera de horario — respuesta en &lt;1 h
          </div>
        </div>

        <!-- Social card -->
        <div class="ct-sidebar-card">
          <h3 class="ct-sidebar-card__title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            Síguenos
          </h3>
          <div class="ct-social-list">
            {SOCIAL_LINKS.map(s => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="ct-social-link"
                style={`--s-color:${s.color}`}
                aria-label={`SIRIUS en ${s.name}`}
              >
                <span set:html={s.icon} />
                {s.name}
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FAQ STRIP
       ══════════════════════════════════════════ -->
  <section class="ct-faq" aria-labelledby="faq-heading">
    <div class="container">
      <div class="ct-faq__header">
        <span class="tag">Preguntas Frecuentes</span>
        <h2 class="ct-faq__title font-display" id="faq-heading">
          Respuestas rápidas
        </h2>
      </div>
      <dl class="ct-faq__grid">
        {FAQS.map(faq => (
          <div class="ct-faq__item">
            <dt class="ct-faq__q">{faq.q}</dt>
            <dd class="ct-faq__a">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       BOTTOM CTA
       ══════════════════════════════════════════ -->
  <section class="ct-bottom-cta">
    <LightBeams variant="hero" />
    <div class="container ct-bottom-cta__inner">
      <h2 class="ct-bottom-cta__title font-display">
        ¿Prefieres chatear? <span class="gradient-text">WhatsApp</span> al instante
      </h2>
      <a
        href="https://wa.me/573163070062?text=Hola%2C%20quiero%20información%20sobre%20productos%20SIRIUS"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--primary btn--lg ct-wa-btn"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.981.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chatear en WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
/* ── Hero ────────────────────────────────────────────────── */
.ct-hero {
  position: relative;
  padding-block: var(--space-16) var(--space-10);
  overflow: hidden;
  background: var(--color-surface-base);
  border-bottom: 1px solid var(--color-surface-border);
}

.ct-hero__glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(90px);
}
.ct-hero__glow--amber {
  top: -40%; left: -10%;
  width: 50vw; height: 450px;
  background: radial-gradient(ellipse, rgba(245,166,35,0.10) 0%, transparent 70%);
}
.ct-hero__glow--blue {
  bottom: -30%; right: 0%;
  width: 35vw; height: 350px;
  background: radial-gradient(ellipse, rgba(0,194,255,0.07) 0%, transparent 70%);
}

.ct-hero__inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.ct-breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
}
.ct-breadcrumb a { color: var(--color-text-tertiary); text-decoration: none; }
.ct-breadcrumb a:hover { color: var(--color-brand-primary); }

.ct-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  color: #22c55e;
  background: rgba(34,197,94,0.10);
  border: 1px solid rgba(34,197,94,0.25);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  width: fit-content;
}

.ct-online-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 8px #22c55e;
  animation: pulse-dot 2.5s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 6px #22c55e; transform: scale(1); }
  50%       { box-shadow: 0 0 14px #22c55e; transform: scale(1.3); }
}

.ct-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--fw-extrabold);
  color: var(--color-text-primary);
  line-height: var(--lh-tight);
  letter-spacing: -0.03em;
  max-width: 18ch;
}

.ct-hero__desc {
  font-size: var(--text-lg);
  color: var(--color-text-secondary);
  max-width: 52ch;
  line-height: var(--lh-relaxed);
}

/* ── Channels ────────────────────────────────────────────── */
.section--sm { padding-block: var(--space-10); }

.ct-channels__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
  gap: var(--space-4);
}

.ct-channel-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  padding: var(--space-5);
  background: var(--ch-bg);
  border: 1.5px solid var(--ch-border);
  border-radius: var(--radius-xl);
  text-decoration: none;
  transition: transform var(--duration-normal) var(--ease-out-expo), box-shadow var(--duration-normal);
  overflow: hidden;
}

.ct-channel-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.25), 0 0 20px var(--ch-bg);
}

.ct-channel-badge {
  position: absolute;
  top: 0.625rem; right: 0.625rem;
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.2rem 0.5rem;
  background: rgba(245,166,35,0.15);
  border: 1px solid rgba(245,166,35,0.35);
  border-radius: var(--radius-full);
  color: var(--color-brand-primary);
}

.ct-channel-icon {
  font-size: 1.5rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.125rem;
}

.ct-channel-body { flex: 1; min-width: 0; }

.ct-channel-label {
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.25rem;
}

.ct-channel-value {
  font-size: var(--text-sm);
  font-weight: var(--fw-bold);
  color: var(--ch-color);
  margin-bottom: 0.25rem;
  word-break: break-all;
}

.ct-channel-desc {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  line-height: 1.4;
}

.ct-channel-arrow {
  color: var(--ch-color);
  opacity: 0.6;
  flex-shrink: 0;
