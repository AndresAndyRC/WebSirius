---
/**
 * Bombillos LED Vintage — Collection page
 * Route: /colecciones/bombillos-vintage
 */
import BaseLayout from '@layouts/BaseLayout.astro';

const products = [
  { name: 'Bombillo LED Vintage Filamento G45 Pinpon 2W',  slug: 'bombillo-led-vintage-de-filamento-g45-pinpon-2w',       watts: 2, forma: 'G45',  rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento G45 Pinpon 4W',  slug: 'bombillo-led-filamento-g45-pinpon-4w',                  watts: 4, forma: 'G45',  rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Filamento 6W Dimerizable',         slug: 'bombillo-led-filamento-6w-dimerizable',                 watts: 6, forma: 'A60',  rosca: 'E27', dimer: true  },
  { name: 'Bombillo LED Vintage Filamento C35 Vela 4W',    slug: 'bombillo-led-filamento-c35-vela-4w-120v-e27-luz-calida', watts: 4, forma: 'C35',  rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento ST64 4W',        slug: 'bombillo-led-filamento-st64-4w-120v-e27-luz-calida',    watts: 4, forma: 'ST64', rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento A60 4W',         slug: 'bombillo-led-filamento-a60-4w-120v-e27-luz-calida',     watts: 4, forma: 'A60',  rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento G80 Globo 4W',   slug: 'bombillo-led-filamento-g80-globo-4w-120v-e27-luz-calida', watts: 4, forma: 'G80', rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento G95 Globo 4W',   slug: 'bombillo-led-filamento-g95-globo-4w-120v-e27-luz-calida', watts: 4, forma: 'G95', rosca: 'E27', dimer: false },
  { name: 'Bombillo LED Vintage Filamento G125 Globo 4W',  slug: 'bombillo-led-filamento-g125-globo-4w-120v-e27luz-calida', watts: 4, forma: 'G125',rosca: 'E27', dimer: false },
  // Accesorios
  { name: 'Portalámpara Colgante Vintage Color Plata', slug: 'portalampara-colgante-vintage-color-plata', watts: 0, forma: 'Accesorio', rosca: '—', dimer: false },
  { name: 'Portalámpara Colgante Vintage Color Cobre', slug: 'portalampara-colgante-vintage-color-cobre', watts: 0, forma: 'Accesorio', rosca: '—', dimer: false },
];

const uniqueFormas = ['G45', 'C35', 'A60', 'ST64', 'G80', 'G95', 'G125'];
const formaIcons: Record<string, string> = { G45:'🔮', C35:'🕯️', A60:'💡', ST64:'💡', G80:'⭕', G95:'⭕', G125:'⭕', Accesorio:'🔩' };
---

<BaseLayout
  title="Bombillos LED Vintage de Filamento — SIRIUS"
  description="Descubre nuestros Bombillos LED Vintage. Filamentos expuestos, luz cálida 2700K y diseños clásicos G45, ST64, A60 y Globo. Alta eficiencia. ¡Compra en SIRIUS!"
  canonical="/colecciones/bombillos-vintage"
  ogImage="/og-default.jpg"
>
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
        <span class="coll-breadcrumb__current">Bombillos Vintage</span>
      </nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Bombillos LED <span class="coll-title--accent">Vintage</span></h1>
      <p class="coll-subtitle">Filamentos expuestos, luz cálida 2700K — G45, C35, ST64, A60 y Globo G80/G95/G125.<br/>Estética retro con eficiencia moderna. Ideales para restaurantes, cafés y ambientes acogedores.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill coll-style-pill--globo">⭕ Globo G80–G125 <em>gran impacto visual</em></span>
        <span class="coll-style-pill coll-style-pill--st64">💡 ST64 Edison <em>clásico filamento</em></span>
        <span class="coll-style-pill coll-style-pill--vela">🕯️ C35 Vela <em>elegante y romántico</em></span>
        <span class="coll-style-pill coll-style-pill--dimer">🎚️ Dimerizable <em>control de intensidad</em></span>
      </div>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros">
        <h2 class="coll-filters__title">Filtrar</h2>
        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Forma / Diseño</legend>
          <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="forma" value="all" checked id="f-all"/><span>Todos</span></label>
          {uniqueFormas.map(f => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="forma" value={f} id={`f-${f}`}/><span>{formaIcons[f]} {f}</span></label>)}
        </fieldset>
        <div class="coll-cert-badges">
          <span class="coll-cert">🕯️ {products.length} productos</span>
          <span class="coll-cert">🔆 Luz Cálida 2700K</span>
          <span class="coll-cert">🚚 Envío nacional</span>
          <span class="coll-cert">⚡ Rosca E27</span>
        </div>
      </aside>

      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
          <button class="coll-mobile-filter-btn" id="filter-toggle" aria-expanded="false" aria-controls="filters-panel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
            Filtros
          </button>
        </div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => (
            <article class="prod-card glass" data-forma={p.forma}>
              <div class="prod-card__strip" aria-hidden="true">
                <div class="prod-card__filament">
                  <span class="prod-card__filament-glow"></span>
                  <span class="prod-card__forma-icon">{formaIcons[p.forma] ?? '💡'}</span>
                </div>
              </div>
              <div class="prod-card__body">
                <div class="prod-card__meta">
                  <span class="prod-card__badge">{p.forma === 'Accesorio' ? '🔩 Accesorio' : `🕯️ ${p.forma}`}</span>
                  {p.dimer && <span class="prod-card__dimer">🎚️ Dimer</span>}
                  {p.rosca !== '—' && <span class="prod-card__install">{p.rosca}</span>}
                </div>
                <h3 class="prod-card__name">{p.name}</h3>
                <div class="prod-card__specs">
                  {p.watts > 0 && <span class="prod-card__spec"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>{p.watts}W</span>}
                  {p.watts > 0 && <span class="prod-card__spec">🔆 2700K Cálida</span>}
                </div>
              </div>
              <a href={`https://siriuscol.com/products/${p.slug}`} class="prod-card__cta" aria-label={`Ver: ${p.name}`} target="_blank" rel="noopener">
                Ver producto <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </article>
          ))}
        </div>
        <div class="coll-empty" id="empty-state" hidden>
          <span class="coll-empty__icon">🕯️</span>
          <p class="coll-empty__text">No se encontraron productos con estos filtros.</p>
          <button class="btn btn--ghost" id="reset-filters">Limpiar filtros</button>
        </div>
      </div>
    </div>
  </section>

  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card"><span class="coll-info-card__icon">🍽️</span><div><strong>Restaurantes y Cafés</strong><p>La luz cálida 2700K crea un ambiente acogedor que realza los colores de los alimentos y el diseño interior.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon">🏡</span><div><strong>Salas y Comedores</strong><p>Los diseños Globo G80–G125 son el punto focal perfecto para comedores y salas de estar.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon">🎚️</span><div><strong>Control de Ambiente</strong><p>El modelo 6W dimerizable permite ajustar la intensidad de luz para cada momento del día.</p></div></div>
    </div>
  </section>

  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿Necesitas lámparas colgantes?</h2>
        <p class="coll-cta-band__sub">Combina estos bombillos vintage con nuestra colección de portalámparas y lámparas colgantes.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/lamparas-colgantes" class="btn btn--ghost">Ver Colgantes</a>
        <a href="/colecciones/bombillos" class="btn btn--ghost">Ver Bombillos LED</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const state = { forma: new Set(['all']) };
  const grid = document.getElementById('products-grid')!;
  const countEl = document.getElementById('product-count')!;
  const emptyEl = document.getElementById('empty-state')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'));
  const checks = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));
  function applyFilters() {
    let vis = 0;
    cards.forEach(c => { const show = state.forma.has('all') || state.forma.has(c.dataset.forma!); c.hidden=!show; if(show)vis++; });
    countEl.textContent=`${vis} producto${vis!==1?'s':''}`;
    emptyEl.hidden=vis>0;
  }
  checks.forEach(cb => cb.addEventListener('change', () => {
    const val=cb.value;
    if(val==='all'){state.forma.clear();state.forma.add('all');checks.filter(c=>c.value!=='all').forEach(c=>{c.checked=false;});cb.checked=true;}
    else{state.forma.delete('all');const a=checks.find(c=>c.value==='all')!;a.checked=false;if(cb.checked)state.forma.add(val);else state.forma.delete(val);if(state.forma.size===0){state.forma.add('all');a.checked=true;}}
    applyFilters();
  }));
  document.getElementById('reset-filters')?.addEventListener('click',()=>{state.forma.clear();state.forma.add('all');checks.forEach(c=>{c.checked=c.value==='all';});applyFilters();});
  document.getElementById('filter-toggle')?.addEventListener('click',function(){const o=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!o));document.getElementById('filters-panel')?.classList.toggle('is-open');});
</script>

<style>
.coll-hero{position:relative;padding:var(--space-16) 0 var(--space-10);overflow:hidden;}
.coll-hero__glow{position:absolute;inset:0;background:radial-gradient(ellipse 65% 60% at 20% 0%,rgba(251,191,36,0.12) 0%,transparent 65%),radial-gradient(ellipse 50% 50% at 80% 100%,rgba(245,166,35,0.07) 0%,transparent 65%);pointer-events:none;}
.coll-breadcrumb{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:var(--space-6);}
.coll-breadcrumb__link{color:var(--color-text-tertiary);transition:color var(--duration-fast);}.coll-breadcrumb__link:hover{color:var(--color-brand-primary);}.coll-breadcrumb__current{color:var(--color-text-secondary);}
.coll-eyebrow{display:inline-block;font-size:var(--text-xs);font-weight:var(--fw-semibold);letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-accent);background:rgba(251,191,36,.10);border:1px solid rgba(251,191,36,.25);padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);margin-bottom:var(--space-5);}
.coll-title{font-family:var(--font-display);font-size:var(--text-4xl);font-weight:var(--fw-extrabold);color:var(--color-text-primary);line-height:var(--lh-tight);margin-bottom:var(--space-4);}
.coll-title--accent{background:linear-gradient(135deg,#FBBF24,#F59E0B,#D97706);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.coll-subtitle{font-size:var(--text-base);color:var(--color-text-secondary);max-width:640px;line-height:var(--lh-normal);margin-bottom:var(--space-8);}
.coll-style-pills{display:flex;flex-wrap:wrap;gap:var(--space-3);}
.coll-style-pill{display:flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:var(--fw-medium);border:1px solid;}
.coll-style-pill em{font-style:normal;font-size:var(--text-xs);opacity:.6;}
.coll-style-pill--globo{background:rgba(251,191,36,.08);border-color:rgba(251,191,36,.25);color:#FBBF24;}
.coll-style-pill--st64{background:rgba(245,166,35,.08);border-color:rgba(245,166,35,.25);color:#F5A623;}
.coll-style-pill--vela{background:rgba(217,119,6,.08);border-color:rgba(217,119,6,.25);color:#D97706;}
.coll-style-pill--dimer{background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA;}
.coll-body{padding-bottom:var(--space-24);}
.coll-layout{display:grid;grid-template-columns:240px 1fr;gap:var(--space-8);align-items:start;}
@media(max-width:860px){.coll-layout{grid-template-columns:1fr;}}
.coll-filters{position:sticky;top:calc(var(--topbar-h) + var(--header-h) + var(--space-4));border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-5);}
@media(max-width:860px){.coll-filters{position:static;display:none;}.coll-filters.is-open{display:flex;}}
.coll-filters__title{font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);letter-spacing:.05em;text-transform:uppercase;}
.coll-filter-group{border:none;padding:0;margin:0;display:flex;flex-direction:column;gap:var(--space-2);}
.coll-filter-group__legend{font-size:var(--text-xs);font-weight:var(--fw-semibold);color:var(--color-text-tertiary);text-transform:uppercase;letter-spacing:.08em;margin-bottom:var(--space-2);}
.coll-filter-chip{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-secondary);cursor:pointer;padding:var(--space-1) var(--space-2);border-radius:var(--radius-sm);transition:color var(--duration-fast),background var(--duration-fast);}
.coll-filter-chip:hover{background:rgba(255,255,255,.04);color:var(--color-text-primary);}
.coll-filter-chip input[type="checkbox"]{accent-color:var(--color-brand-primary);width:15px;height:15px;flex-shrink:0;}
.coll-cert-badges{display:flex;flex-direction:column;gap:var(--space-2);padding-top:var(--space-3);border-top:1px solid var(--color-surface-divider);}
.coll-cert{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.coll-grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);}
.coll-count{font-size:var(--text-sm);color:var(--color-text-tertiary);}
.coll-mobile-filter-btn{display:none;align-items:center;gap:var(--space-2);font-size:var(--text-sm);font-weight:var(--fw-medium);color:var(--color-text-secondary);background:var(--color-surface-raised);border:1px solid var(--color-surface-border);border-radius:var(--radius-md);padding:var(--space-2) var(--space-4);cursor:pointer;}
@media(max-width:860px){.coll-mobile-filter-btn{display:flex;}}
.coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-5);}
.prod-card{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);overflow:hidden;display:flex;flex-direction:column;transition:border-color var(--duration-normal),transform var(--duration-normal) var(--ease-out-expo),box-shadow var(--duration-normal);}
.prod-card:hover{border-color:rgba(251,191,36,.35);transform:translateY(-3px);box-shadow:var(--shadow-md),0 0 30px rgba(251,191,36,.08);}
.prod-card__strip{height:80px;display:flex;align-items:center;justify-content:center;background:radial-gradient(ellipse at 50% 30%,rgba(251,191,36,.22) 0%,rgba(251,191,36,.04) 70%,transparent 100%);position:relative;}
.prod-card__filament{position:relative;display:flex;align-items:center;justify-content:center;}
.prod-card__filament-glow{position:absolute;width:50px;height:50px;border-radius:50%;background:rgba(251,191,36,.18);filter:blur(12px);}
.prod-card__forma-icon{font-size:2.2rem;line-height:1;position:relative;z-index:1;}
.prod-card__body{padding:var(--space-4) var(--space-4) var(--space-3);flex:1;}
.prod-card__meta{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-3);}
.prod-card__badge{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;background:rgba(251,191,36,.10);border-color:rgba(251,191,36,.28);color:#FBBF24;}
.prod-card__dimer{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;background:rgba(96,165,250,.10);border-color:rgba(96,165,250,.28);color:#60A5FA;}
.prod-card__install{font-size:var(--text-xs);color:var(--color-text-tertiary);background:rgba(255,255,255,.04);border:1px solid var(--color-surface-border);padding:2px var(--space-2);border-radius:var(--radius-full);}
.prod-card__name{font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-text-primary);line-height:var(--lh-snug);margin-bottom:var(--space-3);}
.prod-card__specs{display:flex;align-items:center;gap:var(--space-3);flex-wrap:wrap;}
.prod-card__spec{display:flex;align-items:center;gap:var(--space-1);font-size:var(--text-xs);color:var(--color-text-tertiary);}
.prod-card__cta{display:flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-brand-accent);border-top:1px solid var(--color-surface-divider);transition:background var(--duration-fast);}
.prod-card__cta:hover{background:rgba(251,191,36,.06);}
.coll-empty{grid-column:1/-1;text-align:center;padding:var(--space-20) var(--space-8);display:flex;flex-direction:column;align-items:center;gap:var(--space-4);}
.coll-empty__icon{font-size:3rem;}.coll-empty__text{color:var(--color-text-secondary);font-size:var(--text-base);}
.coll-info-strip{background:var(--color-surface-raised);border-top:1px solid var(--color-surface-border);border-bottom:1px solid var(--color-surface-border);padding:var(--space-10) 0;}
.coll-info-strip__inner{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:var(--space-6);}
.coll-info-card{display:flex;align-items:flex-start;gap:var(--space-4);}
.coll-info-card__icon{font-size:2rem;flex-shrink:0;line-height:1;margin-top:.1rem;}
.coll-info-card strong{display:block;font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-info-card p{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);}
.coll-cta-band{background:linear-gradient(135deg,rgba(251,191,36,.07) 0%,rgba(245,166,35,.05) 100%);border-top:1px solid var(--color-surface-border);padding:var(--space-12) 0;}
.coll-cta-band__inner{display:flex;align-items:center;justify-content:space-between;gap:var(--space-8);flex-wrap:wrap;}
.coll-cta-band__title{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-cta-band__sub{font-size:var(--text-sm);color:var(--color-text-secondary);}
.coll-cta-band__actions{display:flex;gap:var(--space-3);flex-wrap:wrap;}
</style>
