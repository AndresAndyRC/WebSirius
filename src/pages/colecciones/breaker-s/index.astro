---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../../utils/imageCheck';

const products = [
  // ── Enchufables ────────────────────────────────────────────
  { name: 'Breaker Enchufable 1P 15A', slug: 'breaker-1p-15a-enchufable', tipo: 'Enchufable', polos: '1P', amperaje: '15A', precio: '$9.600',  desc: '10kA · Curva C' },
  { name: 'Breaker Enchufable 1P 20A', slug: 'breaker-1p-20a-enchufable', tipo: 'Enchufable', polos: '1P', amperaje: '20A', precio: '$11.200', desc: '10kA · Curva C' },
  { name: 'Breaker Enchufable 1P 30A', slug: 'breaker-1p-30a-enchufable', tipo: 'Enchufable', polos: '1P', amperaje: '30A', precio: '$11.200', desc: '10kA · Curva C' },
  { name: 'Breaker Enchufable 2P 40A', slug: 'breaker-1p-40a-enchufable', tipo: 'Enchufable', polos: '2P', amperaje: '40A', precio: '$22.400', desc: '10kA · Curva C · Bipolar' },
  // ── Riel DIN ───────────────────────────────────────────────
  { name: 'Breaker Riel DIN 1P 16A',   slug: 'breaker-riel-1p-63a',   tipo: 'Riel DIN',   polos: '1P', amperaje: '16A', precio: '$10.500', desc: '10kA · Industrial / Residencial' },
  { name: 'Breaker Riel DIN 1P 20A',   slug: 'breaker-1p-20a-enchufable',   tipo: 'Riel DIN',   polos: '1P', amperaje: '20A', precio: '$10.500', desc: '10kA · Industrial / Residencial' },
  { name: 'Breaker Riel DIN 2P 32A',   slug: 'breaker-riel-2p-63a',   tipo: 'Riel DIN',   polos: '2P', amperaje: '32A', precio: '$21.000', desc: '10kA · Bipolar · Industrial' },
  { name: 'Breaker Riel DIN 3P 63A',   slug: 'breaker-riel-3p-63a',   tipo: 'Riel DIN',   polos: '3P', amperaje: '63A', precio: '$36.500', desc: '10kA · Tripolar · Fuerza' },
  // ── Diferencial (Muestra) ───────────────────────────────────
  { name: 'Interruptor Diferencial 2P 40A 30mA',   slug: 'interruptor-diferencial-2p-40a-30ma',   tipo: 'Diferencial', polos: '2P', amperaje: '40A', precio: '$65.000', desc: 'Protección contra fugas a tierra' },
];

const tipos     = ['Enchufable', 'Riel DIN', 'Diferencial'];
const polos     = ['1P', '2P', '3P'];
const amperajes = ['15A', '16A', '20A', '30A', '32A', '40A', '63A'];

const tipoColor: Record<string,string> = { Enchufable: '#60A5FA', 'Riel DIN': '#34D399', Diferencial: '#FB923C' };
const tipoIcon: Record<string,string>  = { Enchufable: 'power_plug', 'Riel DIN': 'settings', Diferencial: 'shield' };
---
<BaseLayout title="Breakers y Protecciones Eléctricas — SIRIUS" description="Encuentra breakers de alta calidad: enchufables y de riel DIN. Capacidad de corte de 10kA. Protección profesional para tu hogar e industria.">
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan"><a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span><a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span><span class="coll-breadcrumb__current">Breakers</span></nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Breakers <span class="coll-title--accent">y Protecciones</span></h1>
      <p class="coll-subtitle">Breakers termomagnéticos enchufables y de riel DIN con capacidad de corte de 10kA. Protege tus circuitos eléctricos con elementos confiables y certificados para uso residencial o industrial.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill" style="background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA"><span class="material-symbols-outlined" style="font-size:1.1em">power_plug</span> Enchufables</span>
        <span class="coll-style-pill" style="background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.25);color:#34D399"><span class="material-symbols-outlined" style="font-size:1.1em">settings</span> Riel DIN</span>
        <span class="coll-style-pill" style="background:rgba(251,146,60,.08);border-color:rgba(251,146,60,.25);color:#FB923C"><span class="material-symbols-outlined" style="font-size:1.1em">shield</span> Diferenciales</span>
        <span class="coll-style-pill" style="background:rgba(168,85,247,.08);border-color:rgba(168,85,247,.25);color:#A855F7"><span class="material-symbols-outlined" style="font-size:1.1em">bolt</span> 10kA</span>
      </div>
    </div>
  </section>
  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel">
        <h2 class="coll-filters__title">Filtrar</h2>
        <fieldset class="coll-filter-group"><legend class="coll-filter-group__legend">Tipo</legend><label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="tipo" value="all" checked/><span>Todos</span></label>
        {tipos.map(v => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="tipo" value={v}/><span><span class="material-symbols-outlined" style="font-size:1.1em;vertical-align:-3px;"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{tipoIcon[v]}</span></span> {v}</span></label>)}</fieldset>
        <fieldset class="coll-filter-group"><legend class="coll-filter-group__legend">Polos</legend><label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="polos" value="all" checked/><span>Todos</span></label>
        {polos.map(v => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="polos" value={v}/><span>{v}</span></label>)}</fieldset>
      </aside>
      <div class="coll-grid-wrap">
        <div class="coll-grid-header"><span class="coll-count" id="product-count">{products.length} productos</span><button class="coll-mobile-filter-btn" id="filter-toggle">Filtros</button></div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const accent = tipoColor[p.tipo]; const icon = tipoIcon[p.tipo];
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
              <article class="prod-card glass" data-tipo={p.tipo} data-polos={p.polos}>
                <div class="prod-card__strip" style={`background:radial-gradient(ellipse at 50% 10%,${accent}22 0%,${accent}08 100%)`} aria-hidden="true">
                  {img1 ? (
                    <div class="prod-card__img-wrap">
                      <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                      {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                    </div>
                  ) : (
                    <span class="prod-card__cat-icon material-symbols-outlined">{icon}</span>
                  )}
                  <div class="prod-card__elec-glow" style={`background:${accent}33;box-shadow:0 0 18px ${accent}44`}></div>
                </div>
                <div class="prod-card__body">
                  <div class="prod-card__meta"><span class="prod-card__badge" style={`background:${accent}18;border-color:${accent}44;color:${accent}`}><span class="material-symbols-outlined" style="font-size:1.1em;vertical-align:-2px"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span></span> {p.tipo}</span><span class="prod-card__badge" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:#cbd5e1">{p.polos} · {p.amperaje}</span></div>
                  <h3 class="prod-card__name">{p.name}</h3><p class="prod-card__desc">{p.desc}</p><p class="prod-card__price">{p.precio} COP</p>
                </div>
                <a href={`https://siriuscol.com/products/${p.slug}`} class="prod-card__cta" target="_blank" rel="noopener">Ver producto</a>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<script>
  type FS = { tipo: Set<string>; polos: Set<string> };
  const state: FS = { tipo: new Set(['all']), polos: new Set(['all']) };
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.prod-card'));
  const checks = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));
  function applyFilters() { let vis = 0; cards.forEach(c => { const show = (state.tipo.has('all') || state.tipo.has(c.dataset.tipo!)) && (state.polos.has('all') || state.polos.has(c.dataset.polos!)); c.hidden = !show; if (show) vis++; }); document.getElementById('product-count')!.textContent = `${vis} productos`; }
  checks.forEach(cb => cb.addEventListener('change', () => { const key = cb.dataset.filter as keyof FS; const val = cb.value; if (val === 'all') { state[key].clear(); state[key].add('all'); checks.filter(c => c.dataset.filter === key && c.value !== 'all').forEach(c => { c.checked = false; }); cb.checked = true; } else { state[key].delete('all'); const allCb = checks.find(c => c.dataset.filter === key && c.value === 'all')!; allCb.checked = false; if (cb.checked) state[key].add(val); else state[key].delete(val); if (state[key].size === 0) { state[key].add('all'); allCb.checked = true; } } applyFilters(); }));
</script>
<style>
.coll-hero{padding:var(--space-16) 0 var(--space-8);position:relative} .coll-title{font-size:var(--text-4xl);font-family:var(--font-display);font-weight:900;margin:0 0 var(--space-4)} .coll-title--accent{background:linear-gradient(135deg,#60A5FA,#34D399);-webkit-background-clip:text;color:transparent} .coll-subtitle{color:var(--color-text-secondary);max-width:600px;margin-bottom:var(--space-6)} .coll-style-pills{display:flex;gap:var(--space-2)} .coll-style-pill{padding:4px 12px;border-radius:100px;border:1px solid;font-size:var(--text-xs)} .coll-breadcrumb{display:flex;gap:var(--space-2);color:var(--color-text-tertiary);font-size:var(--text-xs);margin-bottom:var(--space-4)} .coll-breadcrumb a{color:var(--color-text-tertiary)} .coll-eyebrow{color:var(--color-brand-accent);font-size:10px;text-transform:uppercase;letter-spacing:1px;padding:2px 8px;border-radius:10px;background:rgba(0,194,255,0.1);display:inline-block;margin-bottom:var(--space-4)}
.coll-layout{display:grid;grid-template-columns:220px 1fr;gap:var(--space-8);padding-bottom:var(--space-16)} .coll-filters{padding:var(--space-5);border-radius:var(--radius-xl);border:1px solid rgba(255,255,255,0.1);position:sticky;top:100px} .coll-filter-group{border:none;padding:0;margin:0 0 var(--space-4);display:flex;flex-direction:column;gap:var(--space-2)} .coll-filter-group:last-child{margin:0} .coll-filter-chip{display:flex;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-secondary);cursor:pointer} .coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-5)} .prod-card{border:1px solid rgba(255,255,255,0.1);border-radius:var(--radius-xl);overflow:hidden;display:flex;flex-direction:column} .prod-card__strip{height:200px;display:flex;align-items:center;justify-content:center;position:relative} .prod-card__img-wrap{position:relative;width:100%;height:100%;z-index:2} .prod-card__img{position:absolute;inset:20px;width:calc(100% - 40px);height:calc(100% - 40px);object-fit:contain;transition:opacity 0.6s ease-out,transform 0.6s ease-out;will-change:opacity,transform} .prod-card__img--hover{opacity:0;transform:scale(0.98)} .prod-card:hover .hover-out{opacity:0} .prod-card:hover .prod-card__img--hover{opacity:1;transform:scale(1)} .prod-card__cat-icon{font-size:24px;position:relative;z-index:1} .prod-card__elec-glow{position:absolute;width:60px;height:60px;border-radius:50%;filter:blur(20px)} .prod-card__body{padding:var(--space-4);flex:1} .prod-card__meta{display:flex;gap:var(--space-2);margin-bottom:var(--space-3)} .prod-card__badge{font-size:10px;padding:2px 6px;border-radius:10px;border:1px solid} .prod-card__name{font-size:var(--text-sm);font-weight:600;margin:0 0 var(--space-1)} .prod-card__desc{font-size:var(--text-xs);color:var(--color-text-tertiary);margin:0 0 var(--space-2)} .prod-card__price{font-weight:bold;color:var(--color-brand-primary);margin:0;font-size:var(--text-sm)} .prod-card__cta{display:flex;justify-content:center;padding:var(--space-3);font-size:var(--text-sm);color:var(--color-brand-accent);border-top:1px solid rgba(255,255,255,0.05)}
@media(max-width:800px){.coll-layout{grid-template-columns:1fr} .coll-filters{display:none}}
</style>
