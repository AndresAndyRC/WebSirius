// Color temperature metadata
const colorMeta: Record<string, { label: string; css: string; temp: string; icon: string }> = {
  'Blanca':  { label: 'Luz Blanca',  css: 'cool',    temp: '6000K – 6500K', icon: 'ac_unit' },
  'Neutra':  { label: 'Luz Neutra',  css: 'neutral', temp: '4000K – 4500K', icon: 'sunny' },
  'Cálida':  { label: 'Luz Cálida',  css: 'warm',    temp: '2700K – 3500K', icon: 'local_fire_department' },
};

const uniqueWatts   = [...new Set(products.map(p => p.watts))].sort((a, b) => a - b);
const uniqueColors  = ['Blanca', 'Neutra', 'Cálida'];
const uniqueInstall = ['Incrustar', 'Sobreponer'];
---

<BaseLayout
  title="Paneles LED Redondos | Incrustar y Sobreponer — SIRIUS"
  description="Encuentra la mayor variedad de Paneles LED Redondos en Colombia. Desde 3W hasta 48W, Luz Blanca, neutra o Cálida, para Drywall o Concreto. ¡Renueva con SIRIUS!"
  canonical="/colecciones/paneles-led-redondos"
  ogImage="/og-default.jpg"
>

  <!-- ── Hero ── -->
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a>
        <span aria-hidden="true">›</span>
        <span class="coll-breadcrumb__current">Paneles LED Redondos</span>
      </nav>

      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">
        Paneles LED <span class="coll-title--accent">Redondos</span>
      </h1>
      <p class="coll-subtitle">
        Desde 3W hasta 48W — Incrustar y Sobreponer — Luz Blanca, Neutra o Cálida.
        Certificados RETIE & RETILAP. Envíos a toda Colombia.
      </p>

      <!-- Temperature pills -->
      <div class="coll-temp-pills">
        {uniqueColors.map(c => (
          <span class={`coll-temp-pill coll-temp-pill--${colorMeta[c].css}`}>
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{colorMeta[c].icon}</span> {colorMeta[c].label}
            <em>{colorMeta[c].temp}</em>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Filters + Grid ── -->
  <section class="coll-body">
    <div class="container coll-layout">

      <!-- Sidebar filters -->
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros de productos">
        <h2 class="coll-filters__title">Filtrar</h2>

        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Potencia (W)</legend>
          <label class="coll-filter-chip">
            <input type="checkbox" class="filter-check" data-filter="watts" value="all" checked id="watts-all" />
            <span>Todas</span>
          </label>
          {uniqueWatts.map(w => (
            <label class="coll-filter-chip">
              <input type="checkbox" class="filter-check" data-filter="watts" value={String(w)} id={`watts-${w}`} />
              <span>{w}W</span>
            </label>
          ))}
        </fieldset>

        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Temperatura de color</legend>
          <label class="coll-filter-chip">
            <input type="checkbox" class="filter-check" data-filter="color" value="all" checked id="color-all" />
            <span>Todas</span>
          </label>
          {uniqueColors.map(c => (
            <label class="coll-filter-chip">
              <input type="checkbox" class="filter-check" data-filter="color" value={c} id={`color-${c}`} />
              <span><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{colorMeta[c].icon}</span> {colorMeta[c].label}</span>
            </label>
          ))}
        </fieldset>

        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Tipo de instalación</legend>
          <label class="coll-filter-chip">
            <input type="checkbox" class="filter-check" data-filter="install" value="all" checked id="install-all" />
            <span>Ambos</span>
          </label>
          {uniqueInstall.map(t => (
            <label class="coll-filter-chip">
              <input type="checkbox" class="filter-check" data-filter="install" value={t} id={`install-${t}`} />
              <span>{t}</span>
            </label>
          ))}
        </fieldset>

        <div class="coll-cert-badges">
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">check_circle</span> RETIE</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">check_circle</span> RETILAP</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">local_shipping</span> Envío nacional</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">security</span>️ Garantía 1–5 años</span>
        </div>
      </aside>

      <!-- Product grid -->
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
          <button class="coll-mobile-filter-btn" id="filter-toggle" aria-expanded="false" aria-controls="filters-panel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
            </svg>
            Filtros
          </button>
        </div>

        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
            <article
              class="prod-card glass"
              data-watts={p.watts}
              data-color={p.color}
              data-install={p.install}
            >
              <!-- Visual indicator light -->
              <div class={`prod-card__light prod-card__light--${colorMeta[p.color].css}`} aria-hidden="true">
                {img1 ? (
                  <div class="prod-card__img-wrap group">
                    <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                    {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                  </div>
                ) : (
                  <div class="prod-card__fallback-circle"></div>
                )}
              </div>

              <div class="prod-card__body">
                <div class="prod-card__meta">
                  <span class={`prod-card__temp prod-card__temp--${colorMeta[p.color].css}`}>
                    <span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{colorMeta[p.color].icon}</span> {colorMeta[p.color].label}
                  </span>
                  <span class="prod-card__install">{p.install}</span>
                </div>

                <h3 class="prod-card__name">{p.name}</h3>

                <div class="prod-card__specs">
                  <span class="prod-card__spec">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                    </svg>
                    {p.watts}W
                  </span>
                  <span class="prod-card__spec">{colorMeta[p.color].temp}</span>
                </div>
              </div>

              <a
                href={`https://siriuscol.com/products/${p.slug}`}
                class="prod-card__cta"
                aria-label={`Ver producto: ${p.name}`}
                target="_blank"
                rel="noopener"
              >
                Ver producto
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </article>
            );
          })}
        </div>

        <!-- Empty state -->
        <div class="coll-empty" id="empty-state" hidden>
          <span class="coll-empty__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">flashlight_on</span></span>
          <p class="coll-empty__text">No se encontraron productos con estos filtros.</p>
          <button class="btn btn--ghost" id="reset-filters">Limpiar filtros</button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── CTA band ── -->
  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿Tienes preguntas?</h2>
        <p class="coll-cta-band__sub">Nuestros especialistas te ayudan a elegir el panel correcto para tu espacio.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/faqs" class="btn btn--ghost">Ver FAQs</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // ─── Filter logic ─────────────────────────────────────────
  type FilterState = { watts: Set<string>; color: Set<string>; install: Set<string> };
  const state: FilterState = { watts: new Set(['all']), color: new Set(['all']), install: new Set(['all']) };

  const grid        = document.getElementById('products-grid')!;
  const countEl     = document.getElementById('product-count')!;
  const emptyEl     = document.getElementById('empty-state')!;
  const cards       = Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'));
  const checks      = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const wMatch = state.watts.has('all') || state.watts.has(card.dataset.watts!);
      const cMatch = state.color.has('all')  || state.color.has(card.dataset.color!);
      const iMatch = state.install.has('all') || state.install.has(card.dataset.install!);
      const show   = wMatch && cMatch && iMatch;
      card.hidden = !show;
      if (show) visible++;
    });
    countEl.textContent = `${visible} producto${visible !== 1 ? 's' : ''}`;
    emptyEl.hidden = visible > 0;
  }

  checks.forEach(cb => {
    cb.addEventListener('change', () => {
      const key  = cb.dataset.filter as keyof FilterState;
      const val  = cb.value;

      if (val === 'all') {
        // selecting "all" deselects others
        state[key].clear();
        state[key].add('all');
        checks.filter(c => c.dataset.filter === key && c.value !== 'all')
              .forEach(c => { c.checked = false; });
        cb.checked = true;
      } else {
        state[key].delete('all');
        const allCb = checks.find(c => c.dataset.filter === key && c.value === 'all')!;
        allCb.checked = false;
        if (cb.checked)  state[key].add(val);
        else             state[key].delete(val);
        // if nothing selected, revert to all
        if (state[key].size === 0) {
          state[key].add('all');
          allCb.checked = true;
        }
      }
      applyFilters();
    });
  });

  document.getElementById('reset-filters')?.addEventListener('click', () => {
    (['watts', 'color', 'install'] as const).forEach(key => {
      state[key].clear();
      state[key].add('all');
    });
    checks.forEach(cb => { cb.checked = cb.value === 'all'; });
    applyFilters();
  });

  // Mobile filter toggle
  const filterToggle = document.getElementById('filter-toggle');
  const filtersPanel = document.getElementById('filters-panel');
  filterToggle?.addEventListener('click', () => {
    const open = filterToggle.getAttribute('aria-expanded') === 'true';
    filterToggle.setAttribute('aria-expanded', String(!open));
    filtersPanel?.classList.toggle('is-open');
  });
</script>

<style>
/* ── Hero ─────────────────────────────── */
.coll-hero {
  position: relative;
  padding: var(--space-16) 0 var(--space-10);
  overflow: hidden;
}

.coll-hero__glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 30% 0%, rgba(0,194,255,0.10) 0%, transparent 65%),
    radial-gradient(ellipse 50% 50% at 80% 100%, rgba(245,166,35,0.08) 0%, transparent 65%);
  pointer-events: none;
}

.coll-breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-6);
}
.coll-breadcrumb__link { color: var(--color-text-tertiary); transition: color var(--duration-fast); }
.coll-breadcrumb__link:hover { color: var(--color-brand-primary); }
.coll-breadcrumb__current { color: var(--color-text-secondary); }

