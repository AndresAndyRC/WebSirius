---
/**
 * Cintas LED — Collection page
 * Route: /colecciones/cintas-led
 */
import BaseLayout from '@layouts/BaseLayout.astro';

// ── Color accent map ───────────────────────────────────────
const colorMap: Record<string, string> = {
  Verde:         '#4ADE80',
  Roja:          '#F87171',
  Fucsia:        '#E879F9',
  RGB:           'linear-gradient(90deg,#F87171,#FACC15,#4ADE80,#60A5FA,#E879F9)',
  UV:            '#A78BFA',
  'Luz Blanca':  '#E2F0FF',
  'Luz Neutra':  '#FEF9C3',
  'Luz Cálida':  '#FDE68A',
  Dorada:        '#FCD34D',
  Naranja:       '#FB923C',
  Azul:          '#60A5FA',
  'Azul Aguamarina': '#34D399',
};

const products = [
  // ── Siliconadas 12V ───────────────────────────────────────
  { name: 'Cinta LED 12V Siliconada Verde',       slug: 'cinta-led-12v-siliconada-verde',         voltaje: '12V', tipo: 'Siliconada', color: 'Verde',        price: 21500, agotado: false },
  { name: 'Cinta LED 12V Siliconada Roja',        slug: 'cinta-led-12v-siliconada-roja',          voltaje: '12V', tipo: 'Siliconada', color: 'Roja',         price: 21500, agotado: false },
  { name: 'Cinta LED 12V Siliconada 5M Fucsia',   slug: 'cinta-led-12v-siliconada-fucsia',        voltaje: '12V', tipo: 'Siliconada', color: 'Fucsia',       price: 22000, agotado: false },
  { name: 'Cinta LED 12V Siliconada 5M RGB',      slug: 'cinta-led-12v-siliconada-5m-rgb',        voltaje: '12V', tipo: 'Siliconada', color: 'RGB',          price: 28300, agotado: true  },
  { name: 'Cinta LED 12V Siliconada UV',          slug: 'cinta-led-12v-siliconada-uv',            voltaje: '12V', tipo: 'Siliconada', color: 'UV',           price: 41000, agotado: false },
  // ── Running 12V ───────────────────────────────────────────
  { name: 'Cinta LED Running 12V 10M Luz Blanca', slug: 'cinta-led-running-12v-10m',              voltaje: '12V', tipo: 'Running',    color: 'Luz Blanca',   price: 126100,agotado: false },
  // ── Neón Flex 12V ─────────────────────────────────────────
  { name: 'Cinta LED Neón Flex 12V 5M Dorada',    slug: 'cinta-led-neon-flex-12v-5m-dorada',      voltaje: '12V', tipo: 'Neón Flex',  color: 'Dorada',       price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Naranja',   slug: 'cinta-led-neon-flex-12v-5m-naranja',     voltaje: '12V', tipo: 'Neón Flex',  color: 'Naranja',      price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Fucsia',    slug: 'cinta-led-neon-flex-12v-5m-fucsia',      voltaje: '12V', tipo: 'Neón Flex',  color: 'Fucsia',       price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Roja',      slug: 'cinta-led-neon-flex-12v-5m-roja',        voltaje: '12V', tipo: 'Neón Flex',  color: 'Roja',         price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Verde',     slug: 'cinta-led-neon-flex-12v-5m-verde',       voltaje: '12V', tipo: 'Neón Flex',  color: 'Verde',        price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Azul Aguamarina', slug: 'cinta-led-neon-flex-12v-5m-azul-aguamarina', voltaje: '12V', tipo: 'Neón Flex', color: 'Azul Aguamarina', price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V 5M Azul',      slug: 'cinta-led-neon-flex-12v-5m-azul',        voltaje: '12V', tipo: 'Neón Flex',  color: 'Azul',         price: 22000, agotado: false },
  { name: 'Cinta LED Neón Flex 12V RGB 5M',       slug: 'cinta-led-neon-flex-12v-rgb-5m',         voltaje: '12V', tipo: 'Neón Flex',  color: 'RGB',          price: 62200, agotado: false },
  // ── High Lumen 110V ───────────────────────────────────────
  { name: 'Cinta LED High Lumen 110V 10M Luz Blanca', slug: 'cinta-led-high-lumen-rollo-de-10m-adhesiva-luz-blanca', voltaje: '110V', tipo: 'High Lumen', color: 'Luz Blanca',  price: 175700, agotado: false },
  { name: 'Cinta LED High Lumen 110V 10M Luz Neutra', slug: 'cinta-led-high-lumen-rollo-de-10m-adhesiva-luz-neutra', voltaje: '110V', tipo: 'High Lumen', color: 'Luz Neutra',  price: 175700, agotado: false },
  { name: 'Cinta LED High Lumen 110V 10M Luz Cálida', slug: 'cinta-led-high-lumen-rollo-de-10m-adhesiva-luz-calida', voltaje: '110V', tipo: 'High Lumen', color: 'Luz Cálida',  price: 175700, agotado: false },
  // ── Accesorios ─────────────────────────────────────────────
  { name: 'Conector Cinta LED Running 12V',        slug: 'conector-cinta-led-running-12v',         voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 1000,  agotado: false },
  { name: 'Kit Controlador para Cinta Running 12V',slug: 'kit-controlador-para-cinta-running-12v', voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 20000, agotado: false },
  { name: 'Conector para Cinta LED Neón Flex 12V', slug: 'conector-para-cinta-led-neon-flex-12v',  voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 2000,  agotado: false },
  { name: 'Tapa Cinta Neón Flex 12V',              slug: 'tapa-cinta-neon-flex-12v',               voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 400,   agotado: false },
  { name: 'Grapa Cinta Neón Flex 12V',             slug: 'grapa-cinta-neon-flex-12v',              voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 400,   agotado: false },
  { name: 'Adaptador para Cinta LED 12V 3A',       slug: 'adaptador-para-cinta-led-12v-3a',        voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 19600, agotado: false },
  { name: 'Adaptador para Cinta LED 12V 5A',       slug: 'adaptador-para-cinta-led-12v-5a',        voltaje: '12V', tipo: 'Accesorio',  color: '—',            price: 20200, agotado: false },
  { name: 'Conector Cinta LED High Lumen 110V',    slug: 'conector-cinta-led-high-lumen-110v',     voltaje: '110V', tipo: 'Accesorio', color: '—',            price: 0,     agotado: false },
];

const uniqueVoltajes = ['12V', '110V'];
const uniqueTipos    = ['Siliconada', 'Neón Flex', 'Running', 'High Lumen', 'Accesorio'];
---

<BaseLayout
  title="Cintas LED y Neón Flex 12V y 110V | Iluminación Lineal — SIRIUS"
  description="El catálogo más completo de Cintas LED en Colombia. Cintas 12V para decoración, Neón Flex para avisos y High Lumen 110V para techos. ¡Compra en SIRIUS!"
  canonical="/colecciones/cintas-led"
  ogImage="/og-default.jpg"
>

  <!-- ── Hero ── -->
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a>
        <span aria-hidden="true">›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a>
        <span aria-hidden="true">›</span>
        <span class="coll-breadcrumb__current">Cintas LED</span>
      </nav>

      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">
        Cintas LED <span class="coll-title--accent">&amp; Neón Flex</span>
      </h1>
      <p class="coll-subtitle">
        Siliconadas, Neón Flex y High Lumen — 12V y 110V — RGB, multicolor y blanca.<br/>
        La solución flexible para decoración, avisos comerciales y techos de alto rendimiento.
      </p>

      <div class="coll-style-pills">
        <span class="coll-style-pill coll-style-pill--sili">🎞️ Siliconadas 12V <em>decoración interior</em></span>
        <span class="coll-style-pill coll-style-pill--neon">🌈 Neón Flex 12V <em>avisos &amp; ambientes</em></span>
        <span class="coll-style-pill coll-style-pill--hl">⚡ High Lumen 110V <em>techos comerciales</em></span>
      </div>
    </div>
  </section>

  <!-- ── Filters + Grid ── -->
  <section class="coll-body">
    <div class="container coll-layout">

      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros de productos">
        <h2 class="coll-filters__title">Filtrar</h2>

        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Voltaje</legend>
          <label class="coll-filter-chip">
            <input type="checkbox" class="filter-check" data-filter="voltaje" value="all" checked id="v-all" />
            <span>Todos</span>
          </label>
          {uniqueVoltajes.map(v => (
            <label class="coll-filter-chip">
              <input type="checkbox" class="filter-check" data-filter="voltaje" value={v} id={`v-${v}`} />
              <span>{v}</span>
            </label>
          ))}
        </fieldset>

        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Tipo de cinta</legend>
          <label class="coll-filter-chip">
            <input type="checkbox" class="filter-check" data-filter="tipo" value="all" checked id="t-all" />
            <span>Todos</span>
          </label>
          {uniqueTipos.map(t => (
            <label class="coll-filter-chip">
              <input type="checkbox" class="filter-check" data-filter="tipo" value={t} id={`t-${t.replace(' ','-')}`} />
              <span>{t}</span>
            </label>
          ))}
        </fieldset>

        <div class="coll-cert-badges">
          <span class="coll-cert">🎞️ 25 productos</span>
          <span class="coll-cert">🚚 Envío nacional</span>
          <span class="coll-cert">🛡️ Garantía 1 año</span>
          <span class="coll-cert">⚡ 12V y 110V</span>
        </div>
      </aside>

      <!-- Product grid -->
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
          <button class="coll-mobile-filter-btn" id="filter-toggle" aria-expanded="false" aria-controls="filters-panel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
            </svg>
            Filtros
          </button>
        </div>

        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const accent = colorMap[p.color] ?? '#7EC8FF';
            const isGradient = p.color === 'RGB';
            const isAccesorio = p.tipo === 'Accesorio';
            return (
              <article
                class="prod-card glass"
                data-voltaje={p.voltaje}
                data-tipo={p.tipo}
              >
                <!-- Color strip -->
                <div
                  class="prod-card__strip"
                  style={isGradient
                    ? `background: ${accent}`
                    : `background: radial-gradient(ellipse at 50% 0%, ${accent}44 0%, ${accent}08 100%)`}
                  aria-hidden="true"
                >
                  {isAccesorio ? (
                    <span class="prod-card__strip-icon">🔌</span>
                  ) : isGradient ? (
                    <span class="prod-card__strip-icon">🌈</span>
                  ) : (
                    <div class="prod-card__strip-bar" style={`background:${accent}; box-shadow: 0 0 18px ${accent}99`}></div>
                  )}
                </div>

                <div class="prod-card__body">
                  <div class="prod-card__meta">
                    <span class={`prod-card__badge prod-card__badge--${p.tipo === 'Accesorio' ? 'acc' : p.voltaje === '110V' ? 'hl' : 'led12'}`}>
                      {p.voltaje === '110V' ? '⚡' : '🎞️'} {p.tipo}
                    </span>
                    {p.color !== '—' && (
                      <span class="prod-card__color-dot" style={`background:${isGradient ? 'conic-gradient(#F87171,#FACC15,#4ADE80,#60A5FA,#E879F9,#F87171)' : accent}`} title={p.color}></span>
                    )}
                    {p.agotado && <span class="prod-card__oos">Agotado</span>}
                  </div>

                  <h3 class="prod-card__name">{p.name}</h3>

                  <div class="prod-card__specs">
                    <span class="prod-card__spec">⚡ {p.voltaje}</span>
                    {p.color !== '—' && <span class="prod-card__spec">🎨 {p.color}</span>}
                    {p.price > 0 && (
                      <span class="prod-card__price">${p.price.toLocaleString('es-CO')} COP</span>
                    )}
                  </div>
                </div>

                <a
                  href={`https://siriuscol.com/products/${p.slug}`}
                  class="prod-card__cta"
                  aria-label={`Ver producto: ${p.name}`}
                  target="_blank"
                  rel="noopener"
                >
                  Ver producto
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </a>
              </article>
            );
          })}
        </div>

        <div class="coll-empty" id="empty-state" hidden>
          <span class="coll-empty__icon">🎞️</span>
          <p class="coll-empty__text">No se encontraron productos con estos filtros.</p>
          <button class="btn btn--ghost" id="reset-filters">Limpiar filtros</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Use cases info strip ── -->
  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card">
        <span class="coll-info-card__icon">🏠</span>
        <div>
          <strong>Decoración interior</strong>
          <p>Cintas Siliconadas 12V para muebles, zócalos, escaleras y ambientes. Flexibles, adhesivas y resistentes a humedad leve.</p>
        </div>
      </div>
      <div class="coll-info-card">
        <span class="coll-info-card__icon">🌈</span>
        <div>
          <strong>Avisos comerciales</strong>
          <p>Neón Flex 12V para letras, avisos y marcos decorativos. Doblable sin cortes, efecto neón suavizado y duradero.</p>
        </div>
      </div>
      <div class="coll-info-card">
        <span class="coll-info-card__icon">⚡</span>
        <div>
          <strong>Techos de alto brillo</strong>
          <p>High Lumen 110V conexión directa sin transformador. Ideal para supermercados, talleres y locales de gran metraje.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA band ── -->
  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿Necesitas paneles LED?</h2>
        <p class="coll-cta-band__sub">También tenemos paneles redondos, cuadrados y de grandes dimensiones para todo tipo de techo.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/paneles-led-cuadrados" class="btn btn--ghost">Paneles Cuadrados</a>
        <a href="/colecciones/paneles-led-redondos" class="btn btn--ghost">Paneles Redondos</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  type FilterState = { voltaje: Set<string>; tipo: Set<string> };
  const state: FilterState = { voltaje: new Set(['all']), tipo: new Set(['all']) };

  const grid    = document.getElementById('products-grid')!;
  const countEl = document.getElementById('product-count')!;
  const emptyEl = document.getElementById('empty-state')!;
  const cards   = Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'));
  const checks  = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const vMatch = state.voltaje.has('all') || state.voltaje.has(card.dataset.voltaje!);
      const tMatch = state.tipo.has('all')    || state.tipo.has(card.dataset.tipo!);
      const show   = vMatch && tMatch;
      card.hidden = !show;
      if (show) visible++;
    });
    countEl.textContent = `${visible} producto${visible !== 1 ? 's' : ''}`;
    emptyEl.hidden = visible > 0;
  }

  checks.forEach(cb => {
    cb.addEventListener('change', () => {
      const key = cb.dataset.filter as keyof FilterState;
      const val = cb.value;
      if (val === 'all') {
        state[key].clear(); state[key].add('all');
        checks.filter(c => c.dataset.filter === key && c.value !== 'all').forEach(c => { c.checked = false; });
        cb.checked = true;
      } else {
        state[key].delete('all');
        const allCb = checks.find(c => c.dataset.filter === key && c.value === 'all')!;
        allCb.checked = false;
        if (cb.checked) state[key].add(val); else state[key].delete(val);
        if (state[key].size === 0) { state[key].add('all'); allCb.checked = true; }
      }
      applyFilters();
    });
  });

  document.getElementById('reset-filters')?.addEventListener('click', () => {
    (['voltaje', 'tipo'] as const).forEach(key => { state[key].clear(); state[key].add('all'); });
    checks.forEach(cb => { cb.checked = cb.value === 'all'; });
    applyFilters();
  });

  document.getElementById('filter-toggle')?.addEventListener('click', function() {
    const open = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', String(!open));
    document.getElementById('filters-panel')?.classList.toggle('is-open');
  });
</script>

<style>
/* ── Hero ─────────────────────────────── */
.coll-hero {
  position: relative;
  padding: var(--space-16) 0 var(--space-10);
  overflow: hidden;
}
.coll-hero__glow {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 10% 0%,  rgba(232,121,249,0.10) 0%, transparent 65%),
    radial-gradient(ellipse 50% 50% at 90% 100%, rgba(96,165,250,0.08)  0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 50% 50%,  rgba(74,222,128,0.06)  0%, transparent 70%);
  pointer-events: none;
}
.coll-breadcrumb { display:flex; align-items:center; gap:var(--space-2); font-size:var(--text-xs); color:var(--color-text-tertiary); margin-bottom:var(--space-6); }
.coll-breadcrumb__link { color:var(--color-text-tertiary); transition:color var(--duration-fast); }
.coll-breadcrumb__link:hover { color:var(--color-brand-primary); }
.coll-breadcrumb__current { color:var(--color-text-secondary); }

.coll-eyebrow {
  display:inline-block; font-size:var(--text-xs); font-weight:var(--fw-semibold); letter-spacing:0.12em;
  text-transform:uppercase; color:var(--color-brand-accent);
  background:rgba(0,194,255,0.08); border:1px solid rgba(0,194,255,0.20);
  padding:var(--space-1) var(--space-4); border-radius:var(--radius-full); margin-bottom:var(--space-5);
}
.coll-title { font-family:var(--font-display); font-size:var(--text-4xl); font-weight:var(--fw-extrabold); color:var(--color-text-primary); line-height:var(--lh-tight); margin-bottom:var(--space-4); }
.coll-title--accent { background:linear-gradient(135deg,#E879F9,#60A5FA,#4ADE80); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.coll-subtitle { font-size:var(--text-base); color:var(--color-text-secondary); max-width:640px; line-height:var(--lh-normal); margin-bottom:var(--space-8); }

.coll-style-pills { display:flex; flex-wrap:wrap; gap:var(--space-3); }
.coll-style-pill { display:flex; align-items:center; gap:var(--space-2); padding:var(--space-2) var(--space-4); border-radius:var(--radius-full); font-size:var(--text-sm); font-weight:var(--fw-medium); border:1px solid; }
.coll-style-pill em { font-style:normal; font-size:var(--text-xs); opacity:0.6; }
.coll-style-pill--sili { background:rgba(74,222,128,0.07);  border-color:rgba(74,222,128,0.22);  color:#4ADE80; }
.coll-style-pill--neon  { background:rgba(232,121,249,0.07); border-color:rgba(232,121,249,0.22); color:#E879F9; }
.coll-style-pill--hl    { background:rgba(96,165,250,0.07);  border-color:rgba(96,165,250,0.22);  color:#60A5FA; }

/* ── Layout ───────────────────────────── */
.coll-body { padding-bottom:var(--space-24); }
.coll-layout { display:grid; grid-template-columns:240px 1fr; gap:var(--space-8); align-items:start; }
@media (max-width:860px) { .coll-layout { grid-template-columns:1fr; } }

/* ── Filters sidebar ──────────────────── */
.coll-filters { position:sticky; top:calc(var(--topbar-h) + var(--header-h) + var(--space-4)); border-radius:var(--radius-xl); border:1px solid var(--color-surface-border); padding:var(--space-5); display:flex; flex-direction:column; gap:var(--space-5); }
@media (max-width:860px) { .coll-filters { position:static; display:none; } .coll-filters.is-open { display:flex; } }
.coll-filters__title { font-size:var(--text-sm); font-weight:var(--fw-bold); color:var(--color-text-primary); letter-spacing:0.05em; text-transform:uppercase; }
.coll-filter-group { border:none; padding:0; margin:0; display:flex; flex-direction:column; gap:var(--space-2); }
.coll-filter-group__legend { font-size:var(--text-xs); font-weight:var(--fw-semibold); color:var(--color-text-tertiary); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:var(--space-2); }
.coll-filter-chip { display:flex; align-items:center; gap:var(--space-2); font-size:var(--text-sm); color:var(--color-text-secondary); cursor:pointer; padding:var(--space-1) var(--space-2); border-radius:var(--radius-sm); transition:color var(--duration-fast),background var(--duration-fast); }
.coll-filter-chip:hover { background:rgba(255,255,255,0.04); color:var(--color-text-primary); }
.coll-filter-chip input[type="checkbox"] { accent-color:var(--color-brand-primary); width:15px; height:15px; flex-shrink:0; }
.coll-cert-badges { display:flex; flex-direction:column; gap:var(--space-2); padding-top:var(--space-3); border-top:1px solid var(--color-surface-divider); }
.coll-cert { font-size:var(--text-xs); color:var(--color-text-tertiary); }

/* ── Grid header ──────────────────────── */
.coll-grid-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--space-6); }
.coll-count { font-size:var(--text-sm); color:var(--color-text-tertiary); }
