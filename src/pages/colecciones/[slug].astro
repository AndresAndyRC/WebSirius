---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../utils/imageCheck';
import { COLLECTIONS } from '../../data/colecciones';
import { supabase } from '../../lib/supabase';
import LightBeams from '@components/LightBeams.astro';

export async function getStaticPaths() {
  const { data: todosLosProductos, error } = await supabase.from('productos').select('*');
  if (error) console.error('Error fetching products:', error);

  return COLLECTIONS.map(collection => {
    return {
      params: { slug: collection.id },
      props: { collection, todosLosProductos: todosLosProductos || [] },
    };
  });
}

const { collection, todosLosProductos } = Astro.props;

// Dynamic Category Matching (Fuzzy based on new JSON structure)
const products = todosLosProductos.filter((p: any) => {
  const t = `${p.slug} ${p.title} ${(p.tags || []).join(' ')}`.toLowerCase();
  const c = collection.id;

  if (c === 'paneles-led-redondos') return t.includes('panel') && t.includes('redondo');
  if (c === 'paneles-led-cuadrados') return t.includes('panel') && t.includes('cuadrad');
  if (c === 'paneles-led-grandes-dimensiones') return t.includes('panel') && (t.includes('grande') || t.includes('industrial') || t.includes('60x60') || t.includes('120x30'));
  if (c === 'cintas-led') return t.includes('cinta');
  if (c === 'bombillos') return t.includes('bombillo') && !t.includes('vintage');
  if (c === 'bombillos-vintage') return t.includes('bombillo') && t.includes('vintage');
  if (c === 'lamparas-colgantes') return t.includes('lampara') && (t.includes('colgante') || t.includes('techo'));
  if (c === 'lamparas-alta-potencia') return t.includes('lampara') && (t.includes('potencia') || t.includes('high') || t.includes('ufo'));
  if (c === 'lamparas-escritorio') return t.includes('escritorio');
  if (c === 'apliques-de-pared') return t.includes('aplique');
  if (c === 'balas-led') return t.includes('bala');
  if (c === 'linternas-led') return t.includes('linterna');
  if (c === 'iluminacion-emergencia') return t.includes('emergencia');
  
  if (c === 'lamparas-jardin' || c === 'cintas-led-exterior') return t.includes('exterior') || t.includes('jardin');
  if (c === 'iluminacion-solar') return t.includes('solar');
  if (c === 'balas-led-sumergibles') return t.includes('sumergible') || t.includes('piscina');
  if (c === 'llaves-jardin') return t.includes('llave') && (t.includes('jardin') || t.includes('exterior'));
  if (c === 'extractores-aire') return t.includes('extractor');

  if (c === 'tomacorrientes-interruptores') return t.includes('toma ') || t.includes('interruptor') || t.includes('toma-doble') || t.includes('linea-');
  if (c === 'cables-electricos') return t.includes('cable');
  if (c === 'breaker-s') return t.includes('breaker') || t.includes('disyuntor');
  if (c === 'medidores-y-tableros-electricos') return t.includes('tablero') || t.includes('medidor');
  if (c === 'extension') return t.includes('extension');
  if (c === 'multitomas') return t.includes('multitoma');
  if (c === 'limpiadores-y-lubricantes') return t.includes('limpiador') || t.includes('lubricante') || t.includes('wd40') || t.includes('wd-40');
  
  if (c === 'accesorios-para-bano') return t.includes('baño') || t.includes('bano') || t.includes('ducha');
  if (c === 'llave-de-lavaplatos') return t.includes('lavaplato') || t.includes('griferia');
  if (c === 'accesorios-de-ferreteria') return t.includes('tornillo') || t.includes('amarre') || t.includes('chazo') || t.includes('cinta-');

  // Fallback map check
  let score = 0;
  collection.tags.forEach((tag: string) => {
    if (t.includes(tag.toLowerCase())) score++;
  });
  return score >= 2;
}).map((p: any) => {
  // Inject specs as root properties for filtering and badges
  const enhanced = { ...p };
  if (enhanced.specs && Array.isArray(enhanced.specs)) {
    enhanced.specs.forEach((s: any) => {
      const k = s.label.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
      if (k && s.value) {
        enhanced[k] = s.value;
      }
    });
  }
  return enhanced;
});

// Dynamically extract filters from this collection's products
const excludedKeys = new Set(['id', 'created_at', 'updated_at', 'name', 'slug', 'categoria', 'desc', 'precio', 'price', 'agotado', 'ip', 'control', 'isNew', 'title', 'vendor', 'sku', 'status', 'main_description_html', 'beneficios_html', 'aplicaciones_html', 'specs', 'faqs', 'tags', 'garantia', 'imagenes', 'images', 'url_producto']);
const filterableKeys = new Set<string>();

products.forEach((p: any) => {
  Object.keys(p).forEach(k => {
    // Exclude if it's in the excluded keys list OR if it consists purely of numbers
    if (!excludedKeys.has(k) && !/^\d+$/.test(k)) {
        filterableKeys.add(k);
    }
  });
});


const filters: Record<string, string[]> = {};
filterableKeys.forEach(key => {
  const uniqueVals = new Set<string>();
  products.forEach((p: any) => {
    if (p[key]) uniqueVals.add(String(p[key]));
  });
  if (uniqueVals.size > 0) {
    filters[key] = Array.from(uniqueVals).sort();
  }
});

// Advanced UI config
const themeColors: Record<string, string> = {
  iluminacion: '#F5A623',
  exterior: '#4ADE80',
  electrico: '#00C2FF',
  hogar: '#F472B6',
  especial: '#8B5CF6'
};
const accent = themeColors[collection.category] || '#ef4444';

// Didactic Tips Array
const expertTips = [
  { 
    title: 'Tip del Experto: Watts por Metro Cuadrado', 
    desc: 'La regla dorada para una buena iluminación es calcular entre 4W y 5W de tecnología LED por cada metro cuadrado. Si tu habitación mide 12m², busca paneles que sumen en total unos 60W.',
    icon: 'architecture' 
  },
  { 
    title: 'Tip del Experto: ¿Cálida o Fría?', 
    desc: 'Luz Cálida (3000K) le dice a tu cerebro que es hora de relajarse (ideal para salas y alcobas). Luz Fría (6500K) aumenta la concentración (perfecta para cocinas, estudios o talleres).',
    icon: 'thermostat' 
  }
];
---

<BaseLayout 
  title={`${collection.name} — SIRIUS`} 
  description={collection.description}
>
  <section class="coll-hero">
    <LightBeams variant="subtle" />
    <div class="coll-hero__glow" aria-hidden="true" style={`background: radial-gradient(ellipse at 50% 10%,${accent}22 0%,transparent 70%); filter: blur(80px); width: 100vw; height: 100vh; position: absolute; transform: translate(-50%, -50%); left: 50%; top: 50%; z-index: -1;`}></div>
    <div class="container" style="position: relative; z-index: 2;">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
         <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
         <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
         <span class="coll-breadcrumb__current">{collection.name}</span>
      </nav>
      <span class="coll-eyebrow" style={`color: ${accent}`}>SIRIUS {collection.category.charAt(0).toUpperCase() + collection.category.slice(1)}</span>
      <h1 class="coll-title">{collection.name}</h1>
      <p class="coll-subtitle">{collection.description}</p>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      
      <!-- Dynamic Filter Panel -->
      <aside class="coll-filters" id="filters-panel">
        <div class="coll-filters__header">
          <h2 class="coll-filters__title">
            <span class="material-symbols-outlined">tune</span>
            Filtros
          </h2>
          <button class="coll-filters__reset" id="reset-filters" title="Limpiar filtros">
            <span class="material-symbols-outlined">refresh</span>
          </button>
        </div>
        
        <div class="coll-filters__scroll-area">
        {Object.entries(filters).map(([key, values]) => {
            let displayTitle = key.replace(/-/g, ' ');
            displayTitle = displayTitle.charAt(0).toUpperCase() + displayTitle.slice(1);
            return (
              <details class="coll-filter-group" open>
                <summary class="coll-filter-group__legend">
                  {displayTitle}
                  <span class="material-symbols-outlined expand-icon">expand_more</span>
                </summary>
                <div class="coll-filter-group__options">
                  <label class="coll-filter-chip coll-filter-chip--all">
                    <input type="checkbox" class="filter-check sr-only" data-filter={key} value="all" checked/>
                    <span class="custom-checkbox"></span>
                    <span class="chip-label">Todos</span>
                  </label>
                  {values.map(v => (
                    <label class="coll-filter-chip">
                      <input type="checkbox" class="filter-check sr-only" data-filter={key} value={v}/>
                      <span class="custom-checkbox"></span>
                      <span class="chip-label">{v}</span>
                    </label>
                  ))}
                </div>
              </details>
            );
        })}
        </div>
      </aside>

      <!-- Products Grid -->
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
           <span class="coll-count" id="product-count">{products.length} productos</span>
           
           <div class="coll-quick-pills">
              <button class="didactic-pill" onclick="document.querySelectorAll('.filter-check[value=\'Luz Cálida\'], .filter-check[value=\'3000K\']').forEach(c=>c.click())">
                 <span class="material-symbols-outlined" style="font-size:1.1em;margin-right:4px;">weekend</span> Para Relajarse (3000K)
              </button>
              <button class="didactic-pill" onclick="document.querySelectorAll('.filter-check[value=\'Luz Blanca\'], .filter-check[value=\'6500K\']').forEach(c=>c.click())">
                 <span class="material-symbols-outlined" style="font-size:1.1em;margin-right:4px;">work</span> Para Trabajar (6500K)
              </button>
           </div>
           
           <button class="coll-mobile-filter-btn" id="filter-toggle">Filtros</button>
        </div>
        
        <div class="coll-grid" id="products-grid">
          {products.map((p: any, index: number) => {
            const img1 = getProductImage(p.slug, '1'); 
            const img2 = getProductImage(p.slug, '2');
            
            // Didactic Tip Injection at index 3 and 10
            let tipToInject = null;
            if (index === 3) tipToInject = expertTips[0];
            if (index === 10) tipToInject = expertTips[1];

            // Thermal Aura Detection based on Kelvin
            let tGlow = `rgba(255,255,255,0.05)`;
            let tColor = accent;
            const tempStr = (p['temperatura-de-color'] || p['color'] || '').toLowerCase();
            if (tempStr.includes('calid') || tempStr.includes('3000') || tempStr.includes('cálid')) {
               tGlow = `rgba(245, 166, 35, 0.5)`; tColor = '#F5A623';
            } else if (tempStr.includes('fria') || tempStr.includes('blanca') || tempStr.includes('6500') || tempStr.includes('6000')) {
               tGlow = `rgba(0, 194, 255, 0.5)`; tColor = '#00C2FF';
            } else if (tempStr.includes('neutra') || tempStr.includes('4000')) {
               tGlow = `rgba(255, 255, 255, 0.6)`; tColor = '#E8EFFF';
            }
            
            // Build data attributes dynamically for client JS
            const dataAttrs: any = {};
            Object.keys(filters).forEach(k => {
                dataAttrs[`data-${k}`] = p[k];
            });

            const rawPrice = parseFloat(p.precio || p.price);
            const isZeroPrice = isNaN(rawPrice) || rawPrice === 0;
            const priceDisplay = !isZeroPrice ? `$${rawPrice.toLocaleString('es-CO')}` : null;

            return (
              <>
              {tipToInject && (
                <article class="prod-card glass tip-card educational-glow">
                  <div class="tip-card__icon-wrap">
                     <span class="material-symbols-outlined tip-card__icon">{tipToInject.icon}</span>
                  </div>
                  <div class="tip-card__content">
                     <h3 class="tip-card__title">{tipToInject.title}</h3>
                     <p class="tip-card__desc">{tipToInject.desc}</p>
                  </div>
                </article>
              )}
              <article class="prod-card glass" style={`--hover-glow: ${tGlow}; --card-accent: ${tColor};`} {...dataAttrs}>
                <div class="prod-card__strip" style={`background:radial-gradient(ellipse at 50% 10%, var(--card-accent) 0%, transparent 100%); opacity: 0.8`} aria-hidden="true">
                  {img1 ? (
                    <div class="prod-card__img-wrap group">
                      <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                      {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                    </div>
                  ) : (
                    <span class="prod-card__cat-icon material-symbols-outlined" style="color: var(--card-accent)">{collection.icon}</span>
                  )}
                  <div class="prod-card__elec-glow" style="background:var(--card-accent);box-shadow:0 0 18px var(--card-accent); opacity:0.15"></div>
                </div>
                
                <div class="prod-card__body">
                  <div class="prod-card__meta">
                     {Object.keys(filters).slice(0, 3).map((k) => {
                        if (!p[k]) return null;
                        let valDisplay = String(p[k]);
                        if (k === 'watts') valDisplay += 'W';
                        if (k === 'lumen') valDisplay += ' lm';
                        if (k === 'volt' || k === 'voltaje') valDisplay += 'V';
                        if (k === 'ip') valDisplay = `IP${valDisplay}`;
                        return (
                          <span class="prod-card__badge" style="background:rgba(255,255,255,0.05); border-color:var(--card-accent); color:var(--text-main)">
                            {valDisplay}
                          </span>
                        );
                     })}
                  </div>

                  <h3 class="prod-card__name">{p.title || p.name}</h3>
                  <p class="prod-card__desc line-clamp">{(p.desc || (p.main_description_html || '').replace(/<[^>]*>?/gm, '')).substring(0, 120)}...</p>
                  
                  <div class="prod-card__price-row">
                    {priceDisplay ? (
                        <p class="prod-card__price">{priceDisplay}</p>
                    ) : (
                        <p class="prod-card__price muted">Consultar Precio</p>
                    )}
                  </div>
                </div>

                <a href={`/productos/${p.slug}`} class="prod-card__cta" rel="noopener">
                   Ver Producto
                   <span class="material-symbols-outlined" style="font-size: 1.2em; margin-left: 4px;">arrow_forward</span>
                </a>
              </article>
              </>
            );
          })}
          
          {products.length === 0 && (
             <div class="empty-state">
                <span class="material-symbols-outlined" style="font-size: 3rem; color: var(--text-muted);">inventory_2</span>
                <p>No se encontraron productos en esta colección.</p>
             </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ filterKeys: Object.keys(filters) }}>
  const state = {};
  filterKeys.forEach(k => {
    state[k] = new Set(['all']);
  });
  
  const cards = Array.from(document.querySelectorAll('.prod-card'));
  const checks = Array.from(document.querySelectorAll('.filter-check'));
  
  function applyFilters() { 
    let vis = 0; 
    cards.forEach(c => { 
      let show = true;
      filterKeys.forEach(k => {
         const val = c.dataset[k];
         if (!state[k].has('all') && !state[k].has(val)) {
             show = false;
         }
      });
      c.hidden = !show; 
      if (show) vis++; 
    }); 
    const countEl = document.getElementById('product-count');
    if (countEl) countEl.textContent = `${vis} productos`; 
  }

  checks.forEach(cb => {
    cb.addEventListener('change', () => { 
      const key = cb.dataset.filter; 
      const val = cb.value; 
      
      if (val === 'all') { 
        state[key].clear(); 
        state[key].add('all'); 
        checks.filter(c => c.dataset.filter === key && c.value !== 'all').forEach(c => { c.checked = false; }); 
        cb.checked = true; 
      } else { 
        state[key].delete('all'); 
        const allCb = checks.find(c => c.dataset.filter === key && c.value === 'all'); 
        if (allCb) allCb.checked = false; 
        
        if (cb.checked) state[key].add(val); 
        else state[key].delete(val); 
        
        if (state[key].size === 0) { 
          state[key].add('all'); 
          if (allCb) allCb.checked = true; 
        } 
      } 
      applyFilters(); 
    });
  });

  const resetBtn = document.getElementById('reset-filters');
  if (resetBtn) {
      resetBtn.addEventListener('click', () => {
          checks.forEach(c => {
             if (c.value === 'all') c.checked = true;
             else c.checked = false;
          });
          filterKeys.forEach(k => {
             state[k].clear();
             state[k].add('all');
          });
          applyFilters();
      });
  }
</script>

<style>
/* Base Theme & Layout */
.coll-hero {
    padding: var(--space-20) 0 var(--space-12);
    position: relative;
    overflow: hidden;
}
.coll-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    margin: 0 0 var(--space-4);
    letter-spacing: -0.02em;
    color: var(--text-main, #fff);
}
.coll-subtitle {
    color: var(--text-muted, #94a3b8);
    max-width: 650px;
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: var(--space-6);
}
.coll-breadcrumb {
    display: flex;
    gap: var(--space-2);
    color: var(--text-muted, #94a3b8);
    font-size: 0.85rem;
    margin-bottom: var(--space-6);
}
.coll-breadcrumb a {
    color: var(--text-muted, #94a3b8);
    text-decoration: none;
    transition: color 0.2s;
}
.coll-breadcrumb a:hover {
    color: var(--text-main, #fff);
}
.coll-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 4px 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.05);
    display: inline-block;
    margin-bottom: var(--space-4);
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.coll-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-10);
    padding-bottom: var(--space-20);
}

/* Filters Panel Refined CSS */
.glass {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.coll-filters {
    padding: 0;
    border-radius: 1.25rem;
    position: sticky;
    top: calc(var(--header-height, 80px) + 2rem);
    height: max-content;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.4) 100%);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
}

.coll-filters__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
}

.coll-filters__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-main, #fff);
    letter-spacing: 0.5px;
}

.coll-filters__title .material-symbols-outlined {
    font-size: 1.3rem;
    color: var(--primary, #3b82f6);
}

.coll-filters__reset {
    background: transparent;
    border: none;
    color: var(--text-muted, #94a3b8);
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.coll-filters__reset:hover {
    color: var(--text-main, #fff);
    background: rgba(255, 255, 255, 0.1);
    transform: rotate(90deg);
}

.coll-filters__scroll-area {
    max-height: 65vh;
    overflow-y: auto;
    padding: 0.5rem 1.5rem 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
}
.coll-filters__scroll-area::-webkit-scrollbar {
    width: 6px;
}
.coll-filters__scroll-area::-webkit-scrollbar-track {
    background: transparent;
}
.coll-filters__scroll-area::-webkit-scrollbar-thumb {
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 10px;
}

.coll-filter-group {
    border: none;
    padding: 1.2rem 0;
    margin: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.coll-filter-group:last-child {
    border-bottom: none;
}

.coll-filter-group__legend {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted, #94a3b8);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    transition: color 0.3s;
}
.coll-filter-group__legend::-webkit-details-marker {
    display: none;
}
.coll-filter-group__legend:hover {
    color: var(--text-main, #fff);
}
.coll-filter-group__legend .expand-icon {
    font-size: 1.2rem;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
details[open] .coll-filter-group__legend .expand-icon {
    transform: rotate(180deg);
}

.coll-filter-group__options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
    animation: slideDown 0.3s ease-out forwards;
}

@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}

.coll-filter-chip {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary, #cbd5e1);
    cursor: pointer;
    transition: all 0.2s;
    padding: 0.2rem 0;
}
.coll-filter-chip:hover {
    color: var(--text-main, #fff);
}

.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
}

.custom-checkbox {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
    margin-top: 2px;
    position: relative;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.1);
}

