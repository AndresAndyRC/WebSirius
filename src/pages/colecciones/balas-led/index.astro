---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../../utils/imageCheck';

const products = [
  { name: 'Bala LED Blanca 3W Luz Blanca',         slug: 'bala-led-blanca-3w-luz-blanca',         watts: 3,  lugar: 'Techo', color: 'Blanco', luz: 'Blanca',  forma: 'Cónica' },
  { name: 'Bala LED Negra 3W Luz Blanca',          slug: 'bala-led-negra-3w-luz-blanca',          watts: 3,  lugar: 'Techo', color: 'Negro',  luz: 'Blanca',  forma: 'Cónica' },
  { name: 'Bala LED Negra 3W Luz Cálida',          slug: 'bala-led-negra-3w-luz-calida',          watts: 3,  lugar: 'Techo', color: 'Negro',  luz: 'Cálida',  forma: 'Cónica' },
  { name: 'Bala LED Blanca Redonda 9W Luz Blanca', slug: 'bala-led-blanca-redonda-9w-luz-blanca', watts: 9,  lugar: 'Techo', color: 'Blanco', luz: 'Blanca',  forma: 'Redonda' },
  { name: 'Bala LED Piso 3W Satín Redonda Luz Cálida', slug: 'bala-led-piso-3w-satin-redonda-luz-calida', watts: 3, lugar: 'Piso', color: 'Satín', luz: 'Cálida', forma: 'Redonda' },
  { name: 'Bala LED Piso 6W Satín Redonda Luz Blanca', slug: 'bala-led-piso-6w-satin-redonda-luz-blanca', watts: 6, lugar: 'Piso', color: 'Satín', luz: 'Blanca', forma: 'Redonda' },
  { name: 'Bala LED de Piso GU10 Satín Redonda',   slug: 'bala-led-piso-gu10-satin-redonda',      watts: 0,  lugar: 'Piso', color: 'Satín', luz: '—',      forma: 'GU10' },
];

const lugarColor: Record<string,string> = { Techo: '#60A5FA', Piso: '#4ADE80' };
const formaIcon: Record<string,string>  = { Cónica: 'flashlight_on', Redonda: 'radio_button_unchecked', GU10: 'brightness_high' };
---
<BaseLayout
  title="Balas LED de Piso y Techo para Interior, Exterior y Jardín — SIRIUS"
  description="Encuentra la bala LED perfecta: ojos de buey para techos interiores y balas de piso resistentes para exteriores y jardines. Calidad y Ahorro SIRIUS."
  canonical="/colecciones/balas-led"
  ogImage="/og-default.jpg"
>
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
        <span class="coll-breadcrumb__current">Balas LED</span>
      </nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Balas LED de <span class="coll-title--accent">Piso y Techo</span></h1>
      <p class="coll-subtitle">Empotradas en techo 3W–9W y de piso acero satín 3W–6W — Blanca y Cálida.<br/>Para iluminación direcionada en interiores, jardines, senderos y fachadas residenciales.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill" style="background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">flashlight_on</span> Techo / Ojo de buey <em>interior empotrado</em></span>
        <span class="coll-style-pill" style="background:rgba(74,222,128,.08);border-color:rgba(74,222,128,.25);color:#4ADE80"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">radio_button_unchecked</span> Piso Satín <em>exterior jardín</em></span>
      </div>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros">
        <h2 class="coll-filters__title">Filtrar</h2>
        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Lugar</legend>
          <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="lugar" value="all" checked id="l-all"/><span>Todos</span></label>
          {['Techo','Piso'].map(l => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="lugar" value={l} id={`l-${l}`}/><span>{l === 'Techo' ? 'flashlight_on' : 'radio_button_unchecked'} {l}</span></label>)}
        </fieldset>
        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Luz</legend>
          <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="luz" value="all" checked id="z-all"/><span>Todas</span></label>
          {['Blanca','Cálida'].map(z => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="luz" value={z} id={`z-${z}`}/><span>{z}</span></label>)}
        </fieldset>
        <div class="coll-cert-badges">
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">flashlight_on</span> {products.length} modelos</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">eco</span> Apto exterior</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">local_shipping</span> Envío nacional</span>
        </div>
      </aside>

      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
          <button class="coll-mobile-filter-btn" id="filter-toggle" aria-expanded="false" aria-controls="filters-panel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
            Filtros
          </button>
        </div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const accent = lugarColor[p.lugar];
            const icon = formaIcon[p.forma] ?? 'flashlight_on';
            const isCeil = p.lugar === 'Techo';
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
              <article class="prod-card glass" data-lugar={p.lugar} data-luz={p.luz}>
                <div class="prod-card__strip" style={`background:radial-gradient(ellipse at 50% ${isCeil?'0%':'100%'},${accent}30 0%,${accent}07 100%)`} aria-hidden="true">
                  {img1 ? (
                    <div class="prod-card__img-wrap group">
                      <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                      {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                    </div>
                  ) : (
                    <>
                      {isCeil ? (
                        <div class="prod-card__ceil">
                          <div class="prod-card__ceil-fixture" style={`background:${p.color==='Negro'?'#374151':'#E2F0FF'};box-shadow:0 6px 20px ${accent}66`}></div>
                          <div class="prod-card__ceil-beam" style={`background:linear-gradient(to bottom,${accent}55,transparent)`}></div>
                        </div>
                      ) : (
                        <div class="prod-card__floor">
                          <div class="prod-card__floor-ring" style={`border-color:${accent}88;box-shadow:0 0 18px ${accent}66`}></div>
                          <div class="prod-card__floor-glow" style={`background:${accent}40`}></div>
                        </div>
                      )}
                      <span class="prod-card__lugar-tag" style={`background:${accent}22;color:${accent};border-color:${accent}44`}>{p.lugar}</span>
                    </>
                  )}
                </div>
                <div class="prod-card__body">
                  <div class="prod-card__meta">
                    <span class="prod-card__badge" style={`background:${accent}18;border-color:${accent}44;color:${accent}`}><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span> {p.forma}</span>
                    <span class="prod-card__install">{p.color}</span>
                  </div>
                  <h3 class="prod-card__name">{p.name}</h3>
                  <div class="prod-card__specs">
                    {p.watts>0 && <span class="prod-card__spec"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>{p.watts}W</span>}
                    {p.luz!=='—' && <span class="prod-card__spec"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">brightness_high</span> {p.luz==='Blanca'?'6000K':'3000K'}</span>}
                  </div>
                </div>
                <a href={`https://siriuscol.com/products/${p.slug}`} class="prod-card__cta" aria-label={`Ver: ${p.name}`} target="_blank" rel="noopener">
                  Ver producto <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </article>
            );
          })}
        </div>
        <div class="coll-empty" id="empty-state" hidden>
          <span class="coll-empty__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">flashlight_on</span></span>
          <p class="coll-empty__text">No se encontraron productos con estos filtros.</p>
          <button class="btn btn--ghost" id="reset-filters">Limpiar filtros</button>
        </div>
      </div>
    </div>
  </section>

  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">home</span></span><div><strong>Ojo de Buey en Techo</strong><p>Las balas de techo 3W y 9W se empotran en cielos rasos y yesería. Iluminación focal precisa para cuadros, muebles y áreas.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">eco</span></span><div><strong>Jardín y Senderos</strong><p>Las balas de piso satín en acero inoxidable son resistentes a la intemperie. Perfectas para delimitar caminos y resaltar plantas.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">brightness_high</span></span><div><strong>GU10 Universal</strong><p>La bala GU10 de piso acepta cualquier bombillo dicroico intercambiable. Máxima flexibilidad de color y potencia.</p></div></div>
    </div>
  </section>

  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿También necesitas apliques de pared?</h2>
        <p class="coll-cta-band__sub">Complementa las balas de piso con apliques decorativos para un diseño de iluminación integral.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/apliques-de-pared" class="btn btn--ghost">Ver Apliques</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  type FS2 = { lugar: Set<string>; luz: Set<string> };
  const state: FS2 = { lugar: new Set(['all']), luz: new Set(['all']) };
  const grid = document.getElementById('products-grid')!;
  const countEl = document.getElementById('product-count')!;
  const emptyEl = document.getElementById('empty-state')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'));
  const checks = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));
  function applyFilters(){let vis=0;cards.forEach(c=>{const show=(state.lugar.has('all')||state.lugar.has(c.dataset.lugar!))&&(state.luz.has('all')||state.luz.has(c.dataset.luz!));c.hidden=!show;if(show)vis++;});countEl.textContent=`${vis} producto${vis!==1?'s':''}`;emptyEl.hidden=vis>0;}
  checks.forEach(cb=>cb.addEventListener('change',()=>{const key=cb.dataset.filter as keyof FS2;const val=cb.value;if(val==='all'){state[key].clear();state[key].add('all');checks.filter(c=>c.dataset.filter===key&&c.value!=='all').forEach(c=>{c.checked=false;});cb.checked=true;}else{state[key].delete('all');const a=checks.find(c=>c.dataset.filter===key&&c.value==='all')!;a.checked=false;if(cb.checked)state[key].add(val);else state[key].delete(val);if(state[key].size===0){state[key].add('all');a.checked=true;}}applyFilters();}));
  document.getElementById('reset-filters')?.addEventListener('click',()=>{(['lugar','luz'] as const).forEach(k=>{state[k].clear();state[k].add('all');});checks.forEach(c=>{c.checked=c.value==='all';});applyFilters();});
  document.getElementById('filter-toggle')?.addEventListener('click',function(){const o=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!o));document.getElementById('filters-panel')?.classList.toggle('is-open');});
</script>

<style>
.coll-hero{position:relative;padding:var(--space-16) 0 var(--space-10);overflow:hidden;}
.coll-hero__glow{position:absolute;inset:0;background:radial-gradient(ellipse 60% 55% at 15% 0%,rgba(96,165,250,0.10) 0%,transparent 65%),radial-gradient(ellipse 45% 45% at 85% 100%,rgba(74,222,128,.07) 0%,transparent 65%);pointer-events:none;}
.coll-breadcrumb{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:var(--space-6);}
.coll-breadcrumb__link{color:var(--color-text-tertiary);transition:color var(--duration-fast);}.coll-breadcrumb__link:hover{color:var(--color-brand-primary);}.coll-breadcrumb__current{color:var(--color-text-secondary);}
.coll-eyebrow{display:inline-block;font-size:var(--text-xs);font-weight:var(--fw-semibold);letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-accent);background:rgba(0,194,255,.08);border:1px solid rgba(0,194,255,.20);padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);margin-bottom:var(--space-5);}
.coll-title{font-family:var(--font-display);font-size:var(--text-4xl);font-weight:var(--fw-extrabold);color:var(--color-text-primary);line-height:var(--lh-tight);margin-bottom:var(--space-4);}
.coll-title--accent{background:linear-gradient(135deg,#60A5FA,#4ADE80);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.coll-subtitle{font-size:var(--text-base);color:var(--color-text-secondary);max-width:640px;line-height:var(--lh-normal);margin-bottom:var(--space-8);}
.coll-style-pills{display:flex;flex-wrap:wrap;gap:var(--space-3);}
.coll-style-pill{display:flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:var(--fw-medium);border:1px solid;}
.coll-style-pill em{font-style:normal;font-size:var(--text-xs);opacity:.6;}
.coll-body{padding-bottom:var(--space-24);}
.coll-layout{display:grid;grid-template-columns:240px 1fr;gap:var(--space-8);align-items:start;}
@media(max-width:860px){.coll-layout{grid-template-columns:1fr;}}
.coll-filters{position:sticky;top:calc(var(--topbar-h) + var(--header-h) + var(--space-4));border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-5);}
@media(max-width:860px){.coll-filters{position:static;display:none;}.coll-filters.is-open{display:flex;}}
.coll-filters__title{font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);letter-spacing:.05em;text-transform:uppercase;}
.coll-filter-group{border:none;padding:0;margin:0;display:flex;flex-direction:column;gap:var(--space-2);}
.coll-filter-group__legend{font-size:var(--text-xs);font-weight:var(--fw-semibold);color:var(--color-text-tertiary);text-transform:uppercase;letter-spacing:.08em;margin-bottom:var(--space-2);}
.coll-filter-chip{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-secondary);cursor:pointer;padding:var(--space-1) var(--space-2);border-radius:var(--radius-sm);transition:color var(--duration-fast),background var(--duration-fast);}
.coll-filter-chip:hover{background:rgba(255,255,255,.04);color:var(--color-text-primary);}
.coll-filter-chip input[type="checkbox"]{accent-color:var(--color-brand-primary);width:15px;height:15px;flex-shrink:0;}
.coll-cert-badges{display:flex;flex-direction:column;gap:var(--space-2);padding-top:var(--space-3);border-top:1px solid var(--color-surface-divider);}
.coll-cert{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.coll-grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);}
.coll-count{font-size:var(--text-sm);color:var(--color-text-tertiary);}
.coll-mobile-filter-btn{display:none;align-items:center;gap:var(--space-2);font-size:var(--text-sm);font-weight:var(--fw-medium);color:var(--color-text-secondary);background:var(--color-surface-raised);border:1px solid var(--color-surface-border);border-radius:var(--radius-md);padding:var(--space-2) var(--space-4);cursor:pointer;}
@media(max-width:860px){.coll-mobile-filter-btn{display:flex;}}
.coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-5);}
.prod-card{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);overflow:hidden;display:flex;flex-direction:column;transition:border-color var(--duration-normal),transform var(--duration-normal) var(--ease-out-expo),box-shadow var(--duration-normal);}
.prod-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);}
.prod-card__strip{height:200px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.prod-card__img-wrap{position:relative;width:100%;height:100%;z-index:2} .prod-card__img{position:absolute;inset:20px;width:calc(100% - 40px);height:calc(100% - 40px);object-fit:contain;transition:opacity 0.6s ease-out,transform 0.6s ease-out;will-change:opacity,transform} .prod-card__img--hover{opacity:0;transform:scale(0.98)} .prod-card:hover .hover-out{opacity:0} .prod-card:hover .prod-card__img--hover{opacity:1;transform:scale(1)}
/* Ceiling bulb render */
.prod-card__ceil{display:flex;flex-direction:column;align-items:center;position:relative;}
.prod-card__ceil-fixture{width:36px;height:36px;border-radius:50%;border:2px solid rgba(255,255,255,.2);}
.prod-card__ceil-beam{position:absolute;top:100%;width:50px;height:40px;clip-path:polygon(25%,0,75%,0,100%,100%,0,100%);}
/* Floor ring render */
.prod-card__floor{display:flex;flex-direction:column;align-items:center;gap:0;}
.prod-card__floor-ring{width:46px;height:46px;border-radius:50%;border:3px solid;}
.prod-card__floor-glow{width:60px;height:14px;border-radius:50%;filter:blur(8px);margin-top:-8px;}
/* Tag */
.prod-card__lugar-tag{position:absolute;top:8px;right:10px;font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px 8px;border-radius:var(--radius-full);border:1px solid;}
.prod-card__body{padding:var(--space-4) var(--space-4) var(--space-3);flex:1;}
.prod-card__meta{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-3);}
.prod-card__badge{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;}
.prod-card__install{font-size:var(--text-xs);color:var(--color-text-tertiary);background:rgba(255,255,255,.04);border:1px solid var(--color-surface-border);padding:2px var(--space-2);border-radius:var(--radius-full);}
.prod-card__name{font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-text-primary);line-height:var(--lh-snug);margin-bottom:var(--space-3);}
.prod-card__specs{display:flex;align-items:center;gap:var(--space-3);flex-wrap:wrap;}
.prod-card__spec{display:flex;align-items:center;gap:var(--space-1);font-size:var(--text-xs);color:var(--color-text-tertiary);}
.prod-card__cta{display:flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-brand-accent);border-top:1px solid var(--color-surface-divider);transition:background var(--duration-fast);}
.prod-card__cta:hover{background:rgba(96,165,250,.06);}
.coll-empty{grid-column:1/-1;text-align:center;padding:var(--space-20) var(--space-8);display:flex;flex-direction:column;align-items:center;gap:var(--space-4);}
.coll-empty__icon{font-size:3rem;}.coll-empty__text{color:var(--color-text-secondary);font-size:var(--text-base);}
.coll-info-strip{background:var(--color-surface-raised);border-top:1px solid var(--color-surface-border);border-bottom:1px solid var(--color-surface-border);padding:var(--space-10) 0;}
.coll-info-strip__inner{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:var(--space-6);}
.coll-info-card{display:flex;align-items:flex-start;gap:var(--space-4);}
.coll-info-card__icon{font-size:2rem;flex-shrink:0;line-height:1;margin-top:.1rem;}
.coll-info-card strong{display:block;font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-info-card p{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);}
.coll-cta-band{background:linear-gradient(135deg,rgba(96,165,250,.07) 0%,rgba(74,222,128,.05) 100%);border-top:1px solid var(--color-surface-border);padding:var(--space-12) 0;}
