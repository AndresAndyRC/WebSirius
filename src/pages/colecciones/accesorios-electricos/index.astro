---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../../utils/imageCheck';

const products = [
  { name: 'Convertidor de Redondo a Plano Negro',         slug: 'convertidor-redondo-a-plano-negro',          categoria: 'Convertidor', desc: 'Adaptador enchufe' },
  { name: 'Convertidor Polo a Tierra 3 a 2',             slug: 'convertidor-polo-tierra-3-a-2',              categoria: 'Convertidor', desc: 'Elimina polo tierra' },
  { name: 'Convertidor Polo Tierra 3 a 2 Gris Set x2',   slug: 'convertidor-polo-tierra-3-a-2-gris-set-x2',  categoria: 'Convertidor', desc: 'Pack x2 gris' },
  { name: 'Te Eléctrica Blanca',                         slug: 'te-electrica-blanca',                        categoria: 'Toma', desc: 'Toma múltiple' },
  { name: 'Te Eléctrica Escualizable 10A Blanca UL',      slug: 'te-electrica-escualizable-10a-blanca-ul',    categoria: 'Toma', desc: 'UL certificada 10A' },
  { name: 'Te Eléctrica Escualizable Gris con Polo Tierra',slug: 'te-electrica-ecualizadle-gris-con-polo-a-tierra', categoria: 'Toma', desc: 'Polo a tierra' },
  { name: 'Te Industrial Naranja en Cruz 15A',            slug: 'te-industrial-naranja-en-cruz',              categoria: 'Industrial', desc: 'Cruz 15A' },
  { name: 'Te Industrial Naranja Recta 15A',              slug: 'te-industrial-naranja-recta-15a',            categoria: 'Industrial', desc: 'Recta 15A' },
  { name: 'Tester Probador Corriente Digital Pequeño',    slug: 'tester-probador-corriente-digital-pequeno',  categoria: 'Herramienta', desc: 'Compacto' },
  { name: 'Tester Probador Corriente Digital Grande',     slug: 'tester-probador-corriente-digital-grande',   categoria: 'Herramienta', desc: 'Gran pantalla' },
  { name: 'Interruptor Push Button ON-OFF 15A',           slug: 'interruptor-push-button-on-off-15a',         categoria: 'Interruptor', desc: '15 Amperios' },
  { name: 'Interruptor Push Button ON-OFF 30A',           slug: 'interruptor-push-button-on-off-30a',         categoria: 'Interruptor', desc: '30 Amperios' },
];

const cats = ['Convertidor','Toma','Industrial','Herramienta','Interruptor'];
const catColor: Record<string,string> = { Convertidor:'#94A3B8', Toma:'#60A5FA', Industrial:'#F97316', Herramienta:'#FACC15', Interruptor:'#34D399' };
const catIcon:  Record<string,string>  = { Convertidor:'power', Toma:'bolt', Industrial:'square', Herramienta:'build', Interruptor:'radio_button_checked' };
---
<BaseLayout
  title="Accesorios e Insumos Eléctricos | Tés y Convertidores — SIRIUS"
  description="Asegura y organiza tus instalaciones: tés eléctricas, convertidores de enchufe, testers digitales e interruptores push-button. ¡Compra en SIRIUS!"
  canonical="/colecciones/accesorios-electricos"
  ogImage="/og-default.jpg"
>
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
        <span class="coll-breadcrumb__current">Accesorios Eléctricos</span>
      </nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Accesorios <span class="coll-title--accent">Eléctricos</span></h1>
      <p class="coll-subtitle">Tés eléctricas, convertidores de enchufe, tés industriales, testers y push-buttons — Todo lo que necesitas para organizar y asegurar tus instalaciones eléctricas.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill" style="background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">bolt</span> Tomas múltiples</span>
        <span class="coll-style-pill" style="background:rgba(249,115,22,.08);border-color:rgba(249,115,22,.25);color:#F97316"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">square</span> Industrial 15A</span>
        <span class="coll-style-pill" style="background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.25);color:#34D399"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">radio_button_checked</span> Push-Button 30A</span>
      </div>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros">
        <h2 class="coll-filters__title">Filtrar</h2>
        <fieldset class="coll-filter-group">
          <legend class="coll-filter-group__legend">Categoría</legend>
          <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="cat" value="all" checked id="c-all"/><span>Todos</span></label>
          {cats.map(c => <label class="coll-filter-chip"><input type="checkbox" class="filter-check" data-filter="cat" value={c} id={`c-${c}`}/><span>{catIcon[c]} {c}</span></label>)}
        </fieldset>
        <div class="coll-cert-badges">
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">power</span> {products.length} referencias</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">home</span> Uso residencial</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">factory</span> Uso industrial</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">local_shipping</span> Envío nacional</span>
        </div>
      </aside>
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
          <button class="coll-mobile-filter-btn" id="filter-toggle" aria-expanded="false" aria-controls="filters-panel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>Filtros
          </button>
        </div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const accent = catColor[p.categoria];
            const icon = catIcon[p.categoria];
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
              <article class="prod-card glass" data-cat={p.categoria}>
                <div class="prod-card__strip" style={`background:radial-gradient(ellipse at 50% 10%,${accent}22 0%,${accent}08 100%)`} aria-hidden="true">
                  {img1 ? (
                    <div class="prod-card__img-wrap group">
                      <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                      {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                    </div>
                  ) : (
                    <span class="prod-card__cat-icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span></span>
                  )}
                  <div class="prod-card__elec-glow" style={`background:${accent}33;box-shadow:0 0 18px ${accent}44`}></div>
                </div>
                <div class="prod-card__body">
                  <div class="prod-card__meta">
                    <span class="prod-card__badge" style={`background:${accent}18;border-color:${accent}44;color:${accent}`}><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span> {p.categoria}</span>
                  </div>
                  <h3 class="prod-card__name">{p.name}</h3>
                  <p class="prod-card__desc">{p.desc}</p>
                </div>
                <a href={`https://siriuscol.com/products/${p.slug}`} class="prod-card__cta" aria-label={`Ver: ${p.name}`} target="_blank" rel="noopener">
                  Ver producto <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </article>
            );
          })}
        </div>
        <div class="coll-empty" id="empty-state" hidden>
          <span><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">power</span></span>
          <p style="color:var(--color-text-secondary)">No hay resultados para este filtro.</p>
          <button class="btn btn--ghost" id="reset-filters">Limpiar filtros</button>
        </div>
      </div>
    </div>
  </section>

  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">power</span></span><div><strong>Tomas y Convertidores</strong><p>Tés eléctricas certificadas UL y convertidores de enchufe para adaptar cualquier conector en el hogar u oficina.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">build</span></span><div><strong>Testers Digitales</strong><p>Comprueba tensión, continuidad y polaridad de cualquier circuito. Modelos compacto y de gran pantalla.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">square</span></span><div><strong>Tés Industriales</strong><p>Las tés naranja 15A en cruz y recta son para uso en obras, talleres y eventos. Construcción robusta IP44.</p></div></div>
    </div>
  </section>

  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿También necesitas extractores de aire?</h2>
        <p class="coll-cta-band__sub">Ventilación 4" y 8" para baños, cocinas, bodegas y cuartos de servidores.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/extractores-aire" class="btn btn--ghost">Ver Extractores</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const state = { cat: new Set(['all']) };
  const grid = document.getElementById('products-grid')!;
  const countEl = document.getElementById('product-count')!;
  const emptyEl = document.getElementById('empty-state')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.prod-card'));
  const checks = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-check'));
  function applyFilters(){let vis=0;cards.forEach(c=>{const show=state.cat.has('all')||state.cat.has(c.dataset.cat!);c.hidden=!show;if(show)vis++;});countEl.textContent=`${vis} producto${vis!==1?'s':''}`;emptyEl.hidden=vis>0;}
  checks.forEach(cb=>cb.addEventListener('change',()=>{const val=cb.value;if(val==='all'){state.cat.clear();state.cat.add('all');checks.filter(c=>c.value!=='all').forEach(c=>{c.checked=false;});cb.checked=true;}else{state.cat.delete('all');const a=checks.find(c=>c.value==='all')!;a.checked=false;if(cb.checked)state.cat.add(val);else state.cat.delete(val);if(state.cat.size===0){state.cat.add('all');a.checked=true;}}applyFilters();}));
  document.getElementById('reset-filters')?.addEventListener('click',()=>{state.cat.clear();state.cat.add('all');checks.forEach(c=>{c.checked=c.value==='all';});applyFilters();});
  document.getElementById('filter-toggle')?.addEventListener('click',function(){const o=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!o));document.getElementById('filters-panel')?.classList.toggle('is-open');});
</script>

<style>
.coll-hero{position:relative;padding:var(--space-16) 0 var(--space-10);overflow:hidden;}
.coll-hero__glow{position:absolute;inset:0;background:radial-gradient(ellipse 60% 55% at 15% 0%,rgba(96,165,250,.08) 0%,transparent 65%),radial-gradient(ellipse 45% 45% at 85% 100%,rgba(249,115,22,.06) 0%,transparent 65%);pointer-events:none;}
.coll-breadcrumb{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:var(--space-6);}
.coll-breadcrumb__link{color:var(--color-text-tertiary);transition:color var(--duration-fast);}.coll-breadcrumb__link:hover{color:var(--color-brand-primary);}.coll-breadcrumb__current{color:var(--color-text-secondary);}
.coll-eyebrow{display:inline-block;font-size:var(--text-xs);font-weight:var(--fw-semibold);letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-accent);background:rgba(0,194,255,.08);border:1px solid rgba(0,194,255,.20);padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);margin-bottom:var(--space-5);}
.coll-title{font-family:var(--font-display);font-size:var(--text-4xl);font-weight:var(--fw-extrabold);color:var(--color-text-primary);line-height:var(--lh-tight);margin-bottom:var(--space-4);}
.coll-title--accent{background:linear-gradient(135deg,#60A5FA,#34D399);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.coll-subtitle{font-size:var(--text-base);color:var(--color-text-secondary);max-width:640px;line-height:var(--lh-normal);margin-bottom:var(--space-8);}
.coll-style-pills{display:flex;flex-wrap:wrap;gap:var(--space-3);}
.coll-style-pill{display:flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:var(--fw-medium);border:1px solid;}
.coll-body{padding-bottom:var(--space-24);}
.coll-layout{display:grid;grid-template-columns:240px 1fr;gap:var(--space-8);align-items:start;}
@media(max-width:860px){.coll-layout{grid-template-columns:1fr;}}
.coll-filters{position:sticky;top:calc(var(--topbar-h)+var(--header-h)+var(--space-4));border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-5);}
@media(max-width:860px){.coll-filters{position:static;display:none;}.coll-filters.is-open{display:flex;}}
.coll-filters__title{font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);letter-spacing:.05em;text-transform:uppercase;}
.coll-filter-group{border:none;padding:0;margin:0;display:flex;flex-direction:column;gap:var(--space-2);}
.coll-filter-group__legend{font-size:var(--text-xs);font-weight:var(--fw-semibold);color:var(--color-text-tertiary);text-transform:uppercase;letter-spacing:.08em;margin-bottom:var(--space-2);}
.coll-filter-chip{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-text-secondary);cursor:pointer;padding:var(--space-1) var(--space-2);border-radius:var(--radius-sm);transition:color var(--duration-fast),background var(--duration-fast);}
.coll-filter-chip:hover{background:rgba(255,255,255,.04);color:var(--color-text-primary);}
.coll-filter-chip input[type="checkbox"]{accent-color:var(--color-brand-primary);width:15px;height:15px;flex-shrink:0;}
.coll-cert-badges{display:flex;flex-direction:column;gap:var(--space-2);padding-top:var(--space-3);border-top:1px solid var(--color-surface-divider);}
.coll-cert{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.coll-grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);}
.coll-count{font-size:var(--text-sm);color:var(--color-text-tertiary);}
.coll-mobile-filter-btn{display:none;align-items:center;gap:var(--space-2);font-size:var(--text-sm);font-weight:var(--fw-medium);color:var(--color-text-secondary);background:var(--color-surface-raised);border:1px solid var(--color-surface-border);border-radius:var(--radius-md);padding:var(--space-2) var(--space-4);cursor:pointer;}
@media(max-width:860px){.coll-mobile-filter-btn{display:flex;}}
.coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-5);}
.prod-card{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);overflow:hidden;display:flex;flex-direction:column;transition:border-color var(--duration-normal),transform var(--duration-normal) var(--ease-out-expo),box-shadow var(--duration-normal);}
.prod-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);}
.prod-card__strip{height:200px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.prod-card__img-wrap{position:relative;width:100%;height:100%;z-index:2} .prod-card__img{position:absolute;inset:20px;width:calc(100% - 40px);height:calc(100% - 40px);object-fit:contain;transition:opacity 0.6s ease-out,transform 0.6s ease-out;will-change:opacity,transform} .prod-card__img--hover{opacity:0;transform:scale(0.98)} .prod-card:hover .hover-out{opacity:0} .prod-card:hover .prod-card__img--hover{opacity:1;transform:scale(1)}
.prod-card__cat-icon{font-size:2rem;position:relative;z-index:1;}
.prod-card__elec-glow{position:absolute;width:48px;height:48px;border-radius:50%;filter:blur(14px);}
.prod-card__body{padding:var(--space-4) var(--space-4) var(--space-3);flex:1;}
.prod-card__meta{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-3);}
.prod-card__badge{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;}
.prod-card__name{font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-text-primary);line-height:var(--lh-snug);margin-bottom:var(--space-2);}
.prod-card__desc{font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:0;}
.prod-card__cta{display:flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-brand-accent);border-top:1px solid var(--color-surface-divider);transition:background var(--duration-fast);}
.prod-card__cta:hover{background:rgba(96,165,250,.06);}
.coll-empty{grid-column:1/-1;text-align:center;padding:var(--space-16) var(--space-8);display:flex;flex-direction:column;align-items:center;gap:var(--space-4);font-size:2rem;}
.coll-info-strip{background:var(--color-surface-raised);border-top:1px solid var(--color-surface-border);border-bottom:1px solid var(--color-surface-border);padding:var(--space-10) 0;}
.coll-info-strip__inner{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:var(--space-6);}
.coll-info-card{display:flex;align-items:flex-start;gap:var(--space-4);}
.coll-info-card__icon{font-size:2rem;flex-shrink:0;line-height:1;margin-top:.1rem;}
.coll-info-card strong{display:block;font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-info-card p{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);}
.coll-cta-band{background:linear-gradient(135deg,rgba(96,165,250,.07) 0%,rgba(52,211,153,.05) 100%);border-top:1px solid var(--color-surface-border);padding:var(--space-12) 0;}
.coll-cta-band__inner{display:flex;align-items:center;justify-content:space-between;gap:var(--space-8);flex-wrap:wrap;}
.coll-cta-band__title{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-cta-band__sub{font-size:var(--text-sm);color:var(--color-text-secondary);}
.coll-cta-band__actions{display:flex;gap:var(--space-3);flex-wrap:wrap;}
</style>
