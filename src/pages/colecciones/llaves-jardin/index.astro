---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../../utils/imageCheck';

import todosLosProductos from '../../../data/productos.json';
const products = todosLosProductos.filter(p => p.categoria === 'llaves-jardin');
const tipoColor: Record<string,string> = { Pesada:'#94A3B8', 'Super Pesada':'#60A5FA', Premium:'#FACC15' };
const tipoIcon:  Record<string,string>  = { Pesada:'settings', 'Super Pesada':'settings_applications', Premium:'military_tech' };
---
<BaseLayout
  title="Llaves de Jardín y Grifos de Pared Cromados — SIRIUS"
  description="Grifería que no se rompe. Llaves de Jardín Pesadas, Super Pesadas y Premium con cuerpo metálico cromado. Duraderas y resistentes. ¡Calidad SIRIUS!"
  canonical="/colecciones/llaves-jardin"
  ogImage="/og-default.jpg"
>
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
        <span class="coll-breadcrumb__current">Llaves de Jardín</span>
      </nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Llaves de <span class="coll-title--accent">Jardín</span></h1>
      <p class="coll-subtitle">Pesada, Super Pesada y Premium con palanca — Rosca 1/2" — Cuerpo metálico cromado.<br/>Grifos de jardín que no se parten. Diseñados para uso residencial intensivo y riego profesional.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill" style="background:rgba(148,163,184,.08);border-color:rgba(148,163,184,.25);color:#94A3B8">settings Pesada <em>uso diario</em></span>
        <span class="coll-style-pill" style="background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA">settings_applications Super Pesada <em>máxima durabilidad</em></span>
        <span class="coll-style-pill" style="background:rgba(250,204,21,.08);border-color:rgba(250,204,21,.25);color:#FACC15">military_tech Premium Palanca <em>cuerpo metálico total</em></span>
      </div>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros">
        <h2 class="coll-filters__title">Colección</h2>
        <div class="coll-cert-badges">
          <span class="coll-cert">settings {products.length} modelos</span>
          <span class="coll-cert">home Rosca 1/2"</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">monetization_on</span> Cuerpo cromado</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">local_shipping</span> Envío nacional</span>
        </div>
      </aside>
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
        </div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const accent = tipoColor[p.tipo];
            const icon = tipoIcon[p.tipo];
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
              <article class="prod-card glass">
                <div class="prod-card__strip" style={`background:radial-gradient(ellipse at 50% 10%,${accent}25 0%,${accent}08 100%)`} aria-hidden="true">
                  {img1 ? (
                    <div class="prod-card__img-wrap group">
                      <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                      {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                    </div>
                  ) : (
                    <div class="prod-card__faucet">
                      <div class="prod-card__faucet-body" style={`background:linear-gradient(135deg,${accent}55,${accent}22);border:1px solid ${accent}44`}></div>
                      <div class="prod-card__faucet-handle" style={`background:${accent}88;border:1px solid ${accent}66`}></div>
                      <div class="prod-card__water-drop" style={`background:${accent}`}></div>
                    </div>
                  )}
                  <span class="prod-card__tipo-tag" style={`background:${accent}18;color:${accent};border-color:${accent}44`}><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span> {p.tipo}</span>
                </div>
                <div class="prod-card__body">
                  <div class="prod-card__meta">
                    <span class="prod-card__badge" style={`background:${accent}18;border-color:${accent}44;color:${accent}`}><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">{icon}</span> {p.tipo}</span>
                    <span class="prod-card__install">Rosca 1/2"</span>
                  </div>
                  <h3 class="prod-card__name">{p.name}</h3>
                  <div class="prod-card__specs">
                    <span class="prod-card__spec">monetization_on {p.acabado}</span>
                    <span class="prod-card__spec">settings Metálico</span>
                  </div>
                </div>
                <a href={`/productos/${p.slug}`} class="prod-card__cta" aria-label={`Ver: ${p.name}`} >
                  Ver producto <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card"><span class="coll-info-card__icon">home</span><div><strong>Uso Residencial</strong><p>La llave pesada y super pesada son ideales para casas, apartamentos y locales con uso frecuente de manguera.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon">military_tech</span><div><strong>Premium con Palanca</strong><p>Cuerpo completamente metálico cromado con palanca ergonómica. Máxima durabilidad para uso profesional o agrícola.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon">build</span><div><strong>Instalación Universal</strong><p>Rosca 1/2" estándar compatible con la gran mayoría de tuberías y accesorios hidráulicos en Colombia.</p></div></div>
    </div>
  </section>

  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿También necesitas accesorios eléctricos?</h2>
        <p class="coll-cta-band__sub">Tés eléctricas, convertidores y accesorios de instalación para completar tus proyectos.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/accesorios-electricos" class="btn btn--ghost">Ver Accesorios</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.coll-hero{position:relative;padding:var(--space-16) 0 var(--space-10);overflow:hidden;}
.coll-hero__glow{position:absolute;inset:0;background:radial-gradient(ellipse 60% 55% at 20% 0%,rgba(148,163,184,0.08) 0%,transparent 65%),radial-gradient(ellipse 45% 45% at 80% 100%,rgba(250,204,21,.06) 0%,transparent 65%);pointer-events:none;}
.coll-breadcrumb{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:var(--space-6);}
.coll-breadcrumb__link{color:var(--color-text-tertiary);transition:color var(--duration-fast);}.coll-breadcrumb__link:hover{color:var(--color-brand-primary);}.coll-breadcrumb__current{color:var(--color-text-secondary);}
.coll-eyebrow{display:inline-block;font-size:var(--text-xs);font-weight:var(--fw-semibold);letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-accent);background:rgba(0,194,255,.08);border:1px solid rgba(0,194,255,.20);padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);margin-bottom:var(--space-5);}
.coll-title{font-family:var(--font-display);font-size:var(--text-4xl);font-weight:var(--fw-extrabold);color:var(--color-text-primary);line-height:var(--lh-tight);margin-bottom:var(--space-4);}
.coll-title--accent{background:linear-gradient(135deg,#94A3B8,#FACC15);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.coll-subtitle{font-size:var(--text-base);color:var(--color-text-secondary);max-width:640px;line-height:var(--lh-normal);margin-bottom:var(--space-8);}
.coll-style-pills{display:flex;flex-wrap:wrap;gap:var(--space-3);}
.coll-style-pill{display:flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:var(--fw-medium);border:1px solid;}
.coll-style-pill em{font-style:normal;font-size:var(--text-xs);opacity:.6;}
.coll-body{padding-bottom:var(--space-24);}
.coll-layout{display:grid;grid-template-columns:200px 1fr;gap:var(--space-8);align-items:start;}
@media(max-width:860px){.coll-layout{grid-template-columns:1fr;}}
.coll-filters{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-5);}
.coll-filters__title{font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);letter-spacing:.05em;text-transform:uppercase;}
.coll-cert-badges{display:flex;flex-direction:column;gap:var(--space-2);}
.coll-cert{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.coll-grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);}
.coll-count{font-size:var(--text-sm);color:var(--color-text-tertiary);}
.coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:var(--space-5);}
.prod-card{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);overflow:hidden;display:flex;flex-direction:column;transition:border-color var(--duration-normal),transform var(--duration-normal) var(--ease-out-expo),box-shadow var(--duration-normal);}
.prod-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);}
.prod-card__strip{height:200px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.prod-card__img-wrap{position:relative;width:100%;height:100%;z-index:2} .prod-card__img{position:absolute;inset:20px;width:calc(100% - 40px);height:calc(100% - 40px);object-fit:contain;transition:opacity 0.6s ease-out,transform 0.6s ease-out;will-change:opacity,transform} .prod-card__img--hover{opacity:0;transform:scale(0.98)} .prod-card:hover .hover-out{opacity:0} .prod-card:hover .prod-card__img--hover{opacity:1;transform:scale(1)}
.prod-card__faucet{display:flex;align-items:center;gap:0;position:relative;}
.prod-card__faucet-body{width:32px;height:32px;border-radius:var(--radius-md);}
.prod-card__faucet-handle{width:20px;height:8px;border-radius:var(--radius-full);position:absolute;top:-6px;left:6px;}
.prod-card__water-drop{position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);width:6px;height:8px;border-radius:50% 50% 60% 60%;opacity:.7;}
.prod-card__tipo-tag{position:absolute;top:8px;right:10px;font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px 8px;border-radius:var(--radius-full);border:1px solid;}
.prod-card__body{padding:var(--space-4) var(--space-4) var(--space-3);flex:1;}
.prod-card__meta{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-3);}
.prod-card__badge{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;}
.prod-card__install{font-size:var(--text-xs);color:var(--color-text-tertiary);background:rgba(255,255,255,.04);border:1px solid var(--color-surface-border);padding:2px var(--space-2);border-radius:var(--radius-full);}
.prod-card__name{font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-text-primary);line-height:var(--lh-snug);margin-bottom:var(--space-3);}
.prod-card__specs{display:flex;align-items:center;gap:var(--space-3);flex-wrap:wrap;}
.prod-card__spec{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.prod-card__cta{display:flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-brand-accent);border-top:1px solid var(--color-surface-divider);transition:background var(--duration-fast);}
.prod-card__cta:hover{background:rgba(250,204,21,.05);}
.coll-info-strip{background:var(--color-surface-raised);border-top:1px solid var(--color-surface-border);border-bottom:1px solid var(--color-surface-border);padding:var(--space-10) 0;}
.coll-info-strip__inner{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:var(--space-6);}
.coll-info-card{display:flex;align-items:flex-start;gap:var(--space-4);}
.coll-info-card__icon{font-size:2rem;flex-shrink:0;line-height:1;margin-top:.1rem;}
.coll-info-card strong{display:block;font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-info-card p{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);}
.coll-cta-band{background:linear-gradient(135deg,rgba(148,163,184,.07) 0%,rgba(250,204,21,.05) 100%);border-top:1px solid var(--color-surface-border);padding:var(--space-12) 0;}
.coll-cta-band__inner{display:flex;align-items:center;justify-content:space-between;gap:var(--space-8);flex-wrap:wrap;}
.coll-cta-band__title{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-cta-band__sub{font-size:var(--text-sm);color:var(--color-text-secondary);}
.coll-cta-band__actions{display:flex;gap:var(--space-3);flex-wrap:wrap;}
</style>
