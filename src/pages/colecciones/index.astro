---
/**
 * src/pages/colecciones/index.astro
 * Premium reinvention of siriuscol.com/collections
 * Filtered, searchable catalog with React island + Astro shell.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LightBeams from '@components/LightBeams.astro';
import CollectionFilter from '@components/collections/CollectionFilter.tsx';
import type { Collection } from '@components/collections/CollectionFilter.tsx';

// ─────────────────────────────────────────────────────────
// Full collections data  (preserves original names & hrefs)
// Categories: iluminacion | electrico | exterior | especial | hogar
// ─────────────────────────────────────────────────────────
const BASE = 'https://siriuscol.com/collections/';

import { COLLECTIONS } from '../../data/colecciones';

const STATS = [
  { value: `${COLLECTIONS.length}+`, label: 'Colecciones' },
  { value: '2 años',   label: 'Garantía LED' },
  { value: '<span class="material-symbols-outlined" style="font-size:1.5em;vertical-align:bottom">local_shipping</span>', label: 'Envío a toda Colombia' },
  { value: 'A+',       label: 'Eficiencia Energética' },
];
---

<BaseLayout
  title="Catálogo Completo — SIRIUS Iluminación LED Colombia"
  description="Explora todas las colecciones de SIRIUS: paneles LED, cintas RGB, bombillos vintage, grifería, accesorios eléctricos y más. Envíos a toda Colombia."
  canonical="/colecciones"
  ogType="website"
>
  <!-- ══════════════════════════════════════════
       HERO
       ══════════════════════════════════════════ -->
  <section class="cats-hero">
    <LightBeams variant="subtle" />
    <div class="cats-hero__glow cats-hero__glow--left"  aria-hidden="true"></div>
    <div class="cats-hero__glow cats-hero__glow--right" aria-hidden="true"></div>

    <div class="container cats-hero__inner">
      <!-- Breadcrumb -->
      <nav aria-label="Ruta de navegación" class="cats-breadcrumb">
        <a href="/">Inicio</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Colecciones</span>
      </nav>

      <h1 class="cats-hero__title font-display">
        Todo lo que <span class="gradient-text">ilumina</span><br />
        y potencia tu espacio
      </h1>
      <p class="cats-hero__desc">
        {COLLECTIONS.length} colecciones cuidadosamente seleccionadas: iluminación LED,
        eléctrico, exterior y hogar. Con envíos a toda Colombia y garantía de 2 años.
      </p>

      <!-- Stats strip -->
      <ul class="cats-hero__stats" role="list">
        {STATS.map(s => (
          <li role="listitem" class="cats-stat">
            <span class="cats-stat__value" set:html={s.value}></span>
            <span class="cats-stat__label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       CATEGORY SPOTLIGHT CARDS (static — above fold)
       ══════════════════════════════════════════ -->
  <section class="cats-spotlight section--sm" aria-labelledby="spotlight-heading">
    <div class="container">
      <h2 class="visually-hidden" id="spotlight-heading">Categorías destacadas</h2>
      <div class="cats-spotlight__grid">
        {[
          {
            category: 'iluminacion',
            title: 'Iluminación LED',
            desc: 'Paneles, bombillos, cintas y lámparas con tecnología de última generación.',
            icon: 'lightbulb',
            color: '#F5A623',
            bg: 'rgba(245,166,35,0.07)',
            border: 'rgba(245,166,35,0.20)',
          },
          {
            category: 'electrico',
            title: 'Eléctrico',
            desc: 'Cables, breakers, tableros y todo para una instalación segura y duradera.',
            icon: 'bolt',
            color: '#00C2FF',
            bg: 'rgba(0,194,255,0.07)',
            border: 'rgba(0,194,255,0.20)',
          },
          {
            category: 'exterior',
            title: 'Exterior & Jardín',
            desc: 'Lámparas solares, sumergibles y fachadas. Tu exterior merece brillar.',
            icon: 'eco',
            color: '#4ADE80',
            bg: 'rgba(74,222,128,0.07)',
            border: 'rgba(74,222,128,0.20)',
          },
          {
            category: 'hogar',
            title: 'Hogar & Baño',
            desc: 'Grifería premium, accesorios de baño y detalles que marcan la diferencia.',
            icon: 'home',
            color: '#F472B6',
            bg: 'rgba(244,114,182,0.07)',
            border: 'rgba(244,114,182,0.20)',
          },
        ].map(cat => (
          <div
            class="spotlight-card"
            style={`--s-color:${cat.color};--s-bg:${cat.bg};--s-border:${cat.border}`}
          >
            <div class="spotlight-card__icon material-symbols-outlined">{cat.icon}</div>
            <h3 class="spotlight-card__title">{cat.title}</h3>
            <p class="spotlight-card__desc">{cat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FILTER + GRID (React island — client:load)
       ══════════════════════════════════════════ -->
  <section class="cats-catalog section" aria-labelledby="catalog-heading">
    <div class="container">
      <div class="cats-catalog__header">
        <h2 class="font-display cats-catalog__title" id="catalog-heading">
          Catálogo completo
        </h2>
        <p class="cats-catalog__sub">
          Busca o filtra por categoría para encontrar exactamente lo que necesitas.
        </p>
      </div>
      <CollectionFilter
        client:load
        collections={COLLECTIONS}
      />
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TRUST BANNER
       ══════════════════════════════════════════ -->
  <section class="cats-trust" aria-labelledby="trust-heading">
    <div class="container cats-trust__inner">
      <h2 class="visually-hidden" id="trust-heading">Por qué elegir SIRIUS</h2>
      {[
        { icon: 'local_shipping', title: 'Envío Gratis', desc: 'A toda Colombia en pedidos seleccionados' },
        { icon: 'shield', title: 'Garantía 2 Años', desc: 'Todos nuestros productos LED certificados' },
        { icon: 'lightbulb', title: 'Asesoría Gratuita', desc: 'Expertos disponibles para tu proyecto' },
        { icon: 'recycling', title: 'Ahorro Energético', desc: 'Hasta 80% menos consumo que iluminación tradicional' },
      ].map(item => (
        <div class="trust-item">
          <span class="trust-item__icon material-symbols-outlined" aria-hidden="true">{item.icon}</span>
          <div>
            <p class="trust-item__title">{item.title}</p>
            <p class="trust-item__desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       BOTTOM CTA
       ══════════════════════════════════════════ -->
  <section class="cats-cta">
    <LightBeams variant="hero" />
    <div class="container cats-cta__inner">
      <span class="tag">¿Necesitas asesoría?</span>
      <h2 class="cats-cta__title font-display">
        Nuestros expertos te ayudan a<br />
        <span class="gradient-text">elegir la iluminación perfecta</span>
      </h2>
      <p class="cats-cta__desc">
        Cuéntanos tu proyecto: metraje, uso del espacio y presupuesto.
        Te enviamos la especificación completa sin costo.
      </p>
      <div class="cats-cta__actions">
        <a href="https://wa.me/573163070062" class="btn btn--primary btn--lg" target="_blank" rel="noopener">
          <span class="material-symbols-outlined">chat</span> Chatear en WhatsApp
        </a>
        <a href="/blog" class="btn btn--secondary btn--lg">
          Leer la Guía LED →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ── Hero ────────────────────────────────────────────────── */
.cats-hero {
  position: relative;
  padding-block: var(--space-16) var(--space-12);
  overflow: hidden;
  background: var(--color-surface-base);
  border-bottom: 1px solid var(--color-surface-border);
}

.cats-hero__glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
}

.cats-hero__glow--left {
  top: -30%; left: -10%;
  width: 45vw; height: 400px;
  background: radial-gradient(ellipse, rgba(245,166,35,0.10) 0%, transparent 70%);
}

.cats-hero__glow--right {
  bottom: -30%; right: -5%;
  width: 35vw; height: 350px;
  background: radial-gradient(ellipse, rgba(0,194,255,0.07) 0%, transparent 70%);
}

.cats-hero__inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.cats-breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
}

.cats-breadcrumb a {
  color: var(--color-text-tertiary);
  text-decoration: none;
  transition: color var(--duration-fast);
}

.cats-breadcrumb a:hover { color: var(--color-brand-primary); }

.cats-hero__title {
  font-size: var(--text-5xl);
  font-weight: var(--fw-extrabold);
  color: var(--color-text-primary);
  line-height: var(--lh-tight);
  letter-spacing: -0.03em;
  max-width: 18ch;
}

.cats-hero__desc {
  font-size: var(--text-lg);
  color: var(--color-text-secondary);
  max-width: 52ch;
  line-height: var(--lh-relaxed);
}

/* ─ Stats ─ */
.cats-hero__stats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  list-style: none;
  margin-top: var(--space-2);
}

.cats-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: var(--space-3) var(--space-5);
  background: var(--color-surface-raised);
  border: 1px solid var(--color-surface-border);
  border-radius: var(--radius-lg);
}

.cats-stat__value {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: var(--fw-extrabold);
  color: var(--color-brand-primary);
  line-height: 1;
}

.cats-stat__label {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--fw-medium);
  white-space: nowrap;
}

/* ── Spotlight ───────────────────────────────────────────── */
.section--sm { padding-block: var(--space-10); }

.cats-spotlight__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
  gap: var(--space-4);
}

.spotlight-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-5);
  background: var(--s-bg);
  border: 1px solid var(--s-border);
  border-radius: var(--radius-xl);
  transition: transform var(--duration-normal) var(--ease-out-expo), box-shadow var(--duration-normal);
}

.spotlight-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.25);
}

.spotlight-card__icon {
  font-size: 1.75rem;
  line-height: 1;
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-surface-overlay);
  border-radius: var(--radius-lg);
  border: 1px solid var(--s-border);
}

.spotlight-card__title {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: var(--fw-bold);
  color: var(--s-color);
  line-height: 1.2;
}

.spotlight-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: var(--lh-relaxed);
}

/* ── Catalog ─────────────────────────────────────────────── */
.cats-catalog {
  background: var(--color-surface-base);
  border-top: 1px solid var(--color-surface-border);
}

.cats-catalog__header {
  margin-bottom: var(--space-8);
}

.cats-catalog__title {
  font-size: var(--text-3xl);
  font-weight: var(--fw-bold);
  color: var(--color-text-primary);
  letter-spacing: -0.025em;
  margin-bottom: var(--space-2);
}

.cats-catalog__sub {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
}

/* ── Trust ───────────────────────────────────────────────── */
.cats-trust {
  background: var(--color-surface-raised);
  border-top: 1px solid var(--color-surface-border);
  padding-block: var(--space-10);
}

.cats-trust__inner {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
  gap: var(--space-6);
}

.trust-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
}

.trust-item__icon {
  font-size: 1.75rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.125rem;
}

.trust-item__title {
  font-size: var(--text-sm);
  font-weight: var(--fw-bold);
  color: var(--color-text-primary);
  margin-bottom: 0.25rem;
}

.trust-item__desc {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  line-height: var(--lh-relaxed);
}

/* ── Bottom CTA ──────────────────────────────────────────── */
.cats-cta {
  position: relative;
  text-align: center;
  padding-block: var(--space-20);
  background: var(--color-surface-base);
  border-top: 1px solid var(--color-surface-border);
  overflow: hidden;
}

.cats-cta__inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-5);
}

.cats-cta__title {
  font-size: var(--text-4xl);
  font-weight: var(--fw-bold);
  color: var(--color-text-primary);
  line-height: var(--lh-tight);
  letter-spacing: -0.025em;
}

.cats-cta__desc {
  font-size: var(--text-lg);
  color: var(--color-text-secondary);
  max-width: 50ch;
  line-height: var(--lh-relaxed);
}

.cats-cta__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  justify-content: center;
}
</style>
