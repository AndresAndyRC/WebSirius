---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProductImage } from '../../../utils/imageCheck';

const products = [
  { name: 'Bala LED Sumergible RGB 9W 12V',  slug: 'bala-led-sumergible-12v-rgb-9w',          watts: 9,  control: false, ip: 'IP68' },
  { name: 'Bala LED Sumergible RGB 18W 12V', slug: 'bala-led-sumergible-12v-rgb-18w-con-control', watts: 18, control: true,  ip: 'IP68' },
  { name: 'Bala LED Sumergible RGB 24W 12V', slug: 'bala-led-sumergible-12v-rgb-24w-con-control', watts: 24, control: true,  ip: 'IP68' },
];
---
<BaseLayout
  title="Balas LED Sumergibles para Piscinas 12V RGB — SIRIUS"
  description="Balas LED Sumergibles RGB de 9W, 18W y 24W. Iluminación IP68 segura para piscinas y fuentes. Control remoto incluido. Envíos a todo Colombia. ¡Compra en SIRIUS!"
  canonical="/colecciones/balas-led-sumergibles"
  ogImage="/og-default.jpg"
>
  <section class="coll-hero">
    <div class="coll-hero__glow" aria-hidden="true"></div>
    <div class="container">
      <nav class="coll-breadcrumb" aria-label="Miga de pan">
        <a href="/" class="coll-breadcrumb__link">Inicio</a><span>›</span>
        <a href="/colecciones" class="coll-breadcrumb__link">Colecciones</a><span>›</span>
        <span class="coll-breadcrumb__current">Balas LED Sumergibles</span>
      </nav>
      <span class="coll-eyebrow">Colección</span>
      <h1 class="coll-title">Balas LED <span class="coll-title--accent">Sumergibles</span></h1>
      <p class="coll-subtitle">RGB 9W, 18W y 24W — 12V — IP68 — Control remoto incluido en 18W y 24W.<br/>Iluminación segura para piscinas, fuentes decorativas y láminas de agua. Millones de colores.</p>
      <div class="coll-style-pills">
        <span class="coll-style-pill" style="background:rgba(96,165,250,.08);border-color:rgba(96,165,250,.25);color:#60A5FA"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">water</span> IP68 Sumergible <em>total impermeabilidad</em></span>
        <span class="coll-style-pill" style="background:conic-gradient(#F87171,#FACC15,#4ADE80,#60A5FA,#E879F9,#F87171) border-box;border-color:transparent;color:var(--color-text-primary)"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">palette</span> RGB <em>control remoto</em></span>
        <span class="coll-style-pill" style="background:rgba(74,222,128,.08);border-color:rgba(74,222,128,.25);color:#4ADE80"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">bolt</span> 12V <em>baja tensión segura</em></span>
      </div>
    </div>
  </section>

  <section class="coll-body">
    <div class="container coll-layout">
      <aside class="coll-filters glass" id="filters-panel" aria-label="Filtros">
        <h2 class="coll-filters__title">Colección</h2>
        <div class="coll-cert-badges">
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">water</span> {products.length} modelos</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">palette</span> Millones de colores</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">bolt</span> 12V DC</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">security</span>️ IP68</span>
          <span class="coll-cert"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">local_shipping</span> Envío nacional</span>
        </div>
        <div class="coll-info-mini">
          <p>Todos los modelos requieren transformador 12V (no incluido). Los modelos 18W y 24W incluyen control remoto IR.</p>
        </div>
      </aside>
      <div class="coll-grid-wrap">
        <div class="coll-grid-header">
          <span class="coll-count" id="product-count">{products.length} productos</span>
        </div>
        <div class="coll-grid" id="products-grid">
          {products.map(p => {
            const img1 = getProductImage(p.slug, '1'); const img2 = getProductImage(p.slug, '2');
            return (
            <article class="prod-card glass">
              <div class="prod-card__strip prod-card__strip--rgb" aria-hidden="true">
                {img1 ? (
                  <div class="prod-card__img-wrap group">
                    <img src={img1} alt={p.name} class={`prod-card__img ${img2 ? 'hover-out' : ''}`} loading="lazy" />
                    {img2 && <img src={img2} alt={`${p.name} alternativa`} class="prod-card__img prod-card__img--hover" loading="lazy" />}
                  </div>
                ) : (
                  <>
                    <div class="prod-card__bubble"></div>
                    <div class="prod-card__bubble prod-card__bubble--2"></div>
                    <div class="prod-card__bubble prod-card__bubble--3"></div>
                    <div class="prod-card__pool-glow"></div>
                  </>
                )}
                <span class="prod-card__ip-tag">IP68</span>
              </div>
              <div class="prod-card__body">
                <div class="prod-card__meta">
                  <span class="prod-card__badge-rgb"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">palette</span> RGB</span>
                  {p.control && <span class="prod-card__feature"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">sensors</span> Control remoto</span>}
                  <span class="prod-card__install">12V</span>
                </div>
                <h3 class="prod-card__name">{p.name}</h3>
                <div class="prod-card__specs">
                  <span class="prod-card__spec"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>{p.watts}W</span>
                  <span class="prod-card__spec"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">water</span> {p.ip} Sumergible</span>
                </div>
              </div>
              <a href={`https://siriuscol.com/products/${p.slug}`} class="prod-card__cta" aria-label={`Ver: ${p.name}`} target="_blank" rel="noopener">
                Ver producto <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <section class="coll-info-strip">
    <div class="container coll-info-strip__inner">
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">pool</span></span><div><strong>Piscinas Residenciales</strong><p>Las balas de 9W son ideales para piscinas pequeñas y medianas. Las de 18W y 24W para piscinas olímpicas o comerciales.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">fountain</span></span><div><strong>Fuentes y Láminas de Agua</strong><p>El cuerpo IP68 permite sumersión total. Crea efectos cromáticos espectaculares en fuentes y espejos de agua decorativos.</p></div></div>
      <div class="coll-info-card"><span class="coll-info-card__icon"><span class="material-symbols-outlined" aria-hidden="true" style="font-size:inherit; vertical-align:middle;">bolt</span></span><div><strong>Seguridad 12V</strong><p>Todos los modelos operan a 12V DC, la tensión segura para instalaciones en contacto con agua según normas eléctricas colombianas.</p></div></div>
    </div>
  </section>

  <section class="coll-cta-band">
    <div class="container coll-cta-band__inner">
      <div>
        <h2 class="coll-cta-band__title">¿También necesitas balas LED de techo?</h2>
        <p class="coll-cta-band__sub">Complementa con nuestras balas LED de piso y techo para el área de la piscina y los jardines.</p>
      </div>
      <div class="coll-cta-band__actions">
        <a href="/colecciones/balas-led" class="btn btn--ghost">Ver Balas LED</a>
        <a href="/contacto" class="btn btn--primary">Solicitar asesoría →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.coll-hero{position:relative;padding:var(--space-16) 0 var(--space-10);overflow:hidden;}
.coll-hero__glow{position:absolute;inset:0;background:radial-gradient(ellipse 65% 60% at 20% 0%,rgba(96,165,250,0.14) 0%,transparent 65%),radial-gradient(ellipse 45% 45% at 80% 100%,rgba(232,121,249,.08) 0%,transparent 65%);pointer-events:none;}
.coll-breadcrumb{display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-tertiary);margin-bottom:var(--space-6);}
.coll-breadcrumb__link{color:var(--color-text-tertiary);transition:color var(--duration-fast);}.coll-breadcrumb__link:hover{color:var(--color-brand-primary);}.coll-breadcrumb__current{color:var(--color-text-secondary);}
.coll-eyebrow{display:inline-block;font-size:var(--text-xs);font-weight:var(--fw-semibold);letter-spacing:.12em;text-transform:uppercase;color:#60A5FA;background:rgba(96,165,250,.10);border:1px solid rgba(96,165,250,.25);padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);margin-bottom:var(--space-5);}
.coll-title{font-family:var(--font-display);font-size:var(--text-4xl);font-weight:var(--fw-extrabold);color:var(--color-text-primary);line-height:var(--lh-tight);margin-bottom:var(--space-4);}
.coll-title--accent{background:linear-gradient(135deg,#60A5FA,#E879F9,#4ADE80);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.coll-subtitle{font-size:var(--text-base);color:var(--color-text-secondary);max-width:640px;line-height:var(--lh-normal);margin-bottom:var(--space-8);}
.coll-style-pills{display:flex;flex-wrap:wrap;gap:var(--space-3);}
.coll-style-pill{display:flex;align-items:center;gap:var(--space-2);padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:var(--fw-medium);border:1px solid;}
.coll-style-pill em{font-style:normal;font-size:var(--text-xs);opacity:.6;}
.coll-body{padding-bottom:var(--space-24);}
.coll-layout{display:grid;grid-template-columns:220px 1fr;gap:var(--space-8);align-items:start;}
@media(max-width:860px){.coll-layout{grid-template-columns:1fr;}}
.coll-filters{border-radius:var(--radius-xl);border:1px solid var(--color-surface-border);padding:var(--space-5);display:flex;flex-direction:column;gap:var(--space-5);position:sticky;top:calc(var(--topbar-h)+var(--header-h)+var(--space-4));}
@media(max-width:860px){.coll-filters{position:static;}}
.coll-filters__title{font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);letter-spacing:.05em;text-transform:uppercase;}
.coll-cert-badges{display:flex;flex-direction:column;gap:var(--space-2);}
.coll-cert{font-size:var(--text-xs);color:var(--color-text-tertiary);}
.coll-info-mini{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);padding-top:var(--space-3);border-top:1px solid var(--color-surface-divider);}
.coll-grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-6);}
.coll-count{font-size:var(--text-sm);color:var(--color-text-tertiary);}
.coll-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:var(--space-5);}
.prod-card{border-radius:var(--radius-xl);border:1px solid rgba(96,165,250,.25);overflow:hidden;display:flex;flex-direction:column;transition:border-color var(--duration-normal),transform var(--duration-normal) var(--ease-out-expo),box-shadow var(--duration-normal);}
.prod-card:hover{transform:translateY(-3px);box-shadow:0 8px 32px rgba(96,165,250,.20),var(--shadow-md);}
.prod-card__strip--rgb{height:200px;background:linear-gradient(135deg,#1e3a5f 0%,#1a2744 50%,#1e3a5f 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.prod-card__img-wrap{position:relative;width:100%;height:100%;z-index:2} .prod-card__img{position:absolute;inset:20px;width:calc(100% - 40px);height:calc(100% - 40px);object-fit:contain;transition:opacity 0.6s ease-out,transform 0.6s ease-out;will-change:opacity,transform} .prod-card__img--hover{opacity:0;transform:scale(0.98)} .prod-card:hover .hover-out{opacity:0} .prod-card:hover .prod-card__img--hover{opacity:1;transform:scale(1)}
.prod-card__pool-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(96,165,250,.45) 0%,transparent 60%);}
.prod-card__bubble{position:absolute;border-radius:50%;animation:rise 3s infinite ease-in;}
.prod-card__bubble{width:8px;height:8px;background:rgba(255,255,255,.25);left:30%;bottom:-8px;}
.prod-card__bubble--2{width:5px;height:5px;left:55%;animation-delay:.8s;animation-duration:2.5s;}
.prod-card__bubble--3{width:10px;height:10px;left:70%;animation-delay:1.4s;}
@keyframes rise{0%{transform:translateY(0);opacity:.8;}100%{transform:translateY(-100px);opacity:0;}}
.prod-card__ip-tag{position:absolute;top:8px;right:10px;font-size:var(--text-xs);font-weight:var(--fw-bold);padding:2px 8px;border-radius:var(--radius-full);background:rgba(96,165,250,.22);border:1px solid rgba(96,165,250,.50);color:#7EC8FF;}
.prod-card__body{padding:var(--space-4) var(--space-4) var(--space-3);flex:1;}
.prod-card__meta{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-3);}
.prod-card__badge-rgb{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);background:linear-gradient(90deg,rgba(248,113,113,.25),rgba(232,121,249,.25),rgba(96,165,250,.25));border:1px solid rgba(255,255,255,.20);color:var(--color-text-primary);}
.prod-card__feature{font-size:var(--text-xs);font-weight:var(--fw-semibold);padding:2px var(--space-2);border-radius:var(--radius-full);border:1px solid;background:rgba(74,222,128,.10);border-color:rgba(74,222,128,.28);color:#4ADE80;}
.prod-card__install{font-size:var(--text-xs);color:var(--color-text-tertiary);background:rgba(255,255,255,.04);border:1px solid var(--color-surface-border);padding:2px var(--space-2);border-radius:var(--radius-full);}
.prod-card__name{font-size:var(--text-sm);font-weight:var(--fw-semibold);color:var(--color-text-primary);line-height:var(--lh-snug);margin-bottom:var(--space-3);}
.prod-card__specs{display:flex;align-items:center;gap:var(--space-3);flex-wrap:wrap;}
.prod-card__spec{display:flex;align-items:center;gap:var(--space-1);font-size:var(--text-xs);color:var(--color-text-tertiary);}
.prod-card__cta{display:flex;align-items:center;justify-content:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);font-size:var(--text-sm);font-weight:var(--fw-semibold);color:#7EC8FF;border-top:1px solid var(--color-surface-divider);transition:background var(--duration-fast);}
.prod-card__cta:hover{background:rgba(96,165,250,.07);}
.coll-info-strip{background:var(--color-surface-raised);border-top:1px solid var(--color-surface-border);border-bottom:1px solid var(--color-surface-border);padding:var(--space-10) 0;}
.coll-info-strip__inner{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));gap:var(--space-6);}
.coll-info-card{display:flex;align-items:flex-start;gap:var(--space-4);}
.coll-info-card__icon{font-size:2rem;flex-shrink:0;line-height:1;margin-top:.1rem;}
.coll-info-card strong{display:block;font-size:var(--text-sm);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-info-card p{font-size:var(--text-xs);color:var(--color-text-tertiary);line-height:var(--lh-relaxed);}
.coll-cta-band{background:linear-gradient(135deg,rgba(96,165,250,.07) 0%,rgba(232,121,249,.04) 100%);border-top:1px solid var(--color-surface-border);padding:var(--space-12) 0;}
.coll-cta-band__inner{display:flex;align-items:center;justify-content:space-between;gap:var(--space-8);flex-wrap:wrap;}
.coll-cta-band__title{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--fw-bold);color:var(--color-text-primary);margin-bottom:var(--space-1);}
.coll-cta-band__sub{font-size:var(--text-sm);color:var(--color-text-secondary);}
.coll-cta-band__actions{display:flex;gap:var(--space-3);flex-wrap:wrap;}
</style>
