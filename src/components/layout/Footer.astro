---
/**
 * Footer.astro — Site footer with links, social, and brand info
 */
const year = new Date().getFullYear();

const quickLinks = [
  { label: 'Productos',       href: 'https://siriuscol.com/collections' },
  { label: 'Blog',            href: '/blog' },
  { label: 'Preguntas Frecuentes', href: 'https://siriuscol.com/pages/pushdaddy-faq-1' },
  { label: 'Contacto',        href: 'https://siriuscol.com/pages/contact' },
];

const legalLinks = [
  { label: 'Política de privacidad', href: 'https://siriuscol.com/policies/privacy-policy' },
  { label: 'Términos y condiciones', href: 'https://siriuscol.com/policies/terms-of-service' },
  { label: 'Política de devoluciones', href: 'https://siriuscol.com/policies/refund-policy' },
  { label: 'Política de envíos',     href: 'https://siriuscol.com/policies/shipping-policy' },
];

const socialLinks = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=100090449014923',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/siriuscol_com',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'TikTok',
    href: 'https://www.tiktok.com/@siriushopm',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V9.07a8.16 8.16 0 0 0 4.77 1.52V7.14a4.85 4.85 0 0 1-1-.45z"/></svg>`,
  },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__glow" aria-hidden="true"></div>
  <div class="container">
    <!-- Brand row -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="SIRIUS Iluminación — Inicio">
        <span class="footer__logo-mark" aria-hidden="true">✦</span>
        <span class="footer__logo-text font-display">SIRIUS</span>
      </a>
      <p class="footer__tagline">
        La tecnología LED más avanzada para transformar tus espacios.<br />
        Fusagasugá, Cundinamarca · Colombia.
      </p>
      <div class="footer__social" role="list" aria-label="Redes sociales">
        {socialLinks.map(s => (
          <a
            href={s.href}
            class="footer__social-link"
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            set:html={s.icon}
          />
        ))}
      </div>
    </div>

    <!-- Links grid -->
    <div class="footer__links">
      <div class="footer__col">
        <h3 class="footer__col-title">Navegación</h3>
        <ul>
          {quickLinks.map(l => (
            <li><a href={l.href} class="footer__link">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer__col">
        <h3 class="footer__col-title">Legal</h3>
        <ul>
          {legalLinks.map(l => (
            <li><a href={l.href} class="footer__link" target="_blank" rel="noopener">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer__col">
        <h3 class="footer__col-title">Contacto</h3>
        <address class="footer__address">
          <p>Calle 22 # 49-36</p>
          <p>Fusagasugá, Cundinamarca</p>
          <a href="tel:+573163070062" class="footer__link">+57 316 307 0062</a>
          <a href="mailto:gerencia@steelplanet.com.co" class="footer__link">gerencia@steelplanet.com.co</a>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {year} SIRIUS Iluminación. Todos los derechos reservados.
      </p>
      <p class="footer__made">
        Diseño premium · Tecnología LED colombiana
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  position: relative;
  background: var(--color-surface-raised);
  border-top: 1px solid var(--color-surface-border);
  padding-top: var(--space-16);
  overflow: hidden;
}

.footer__glow {
  position: absolute;
  bottom: -60%;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 300px;
  background: radial-gradient(ellipse, rgba(245,166,35,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.footer > .container {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
}

@media (min-width: 768px) {
  .footer > .container {
    grid-template-columns: 1fr 2fr;
    gap: var(--space-16);
  }
}

/* Brand */
.footer__logo {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}
.footer__logo-mark { font-size: var(--text-xl); color: var(--color-brand-primary); }
.footer__logo-text { font-size: var(--text-2xl); font-weight: var(--fw-bold); color: var(--color-text-primary); letter-spacing: -0.02em; }

.footer__tagline {
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
  line-height: var(--lh-relaxed);
  margin-bottom: var(--space-6);
}

.footer__social {
  display: flex;
  gap: var(--space-3);
}

.footer__social-link {
  width: 40px; height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--color-surface-overlay);
  border: 1px solid var(--color-surface-border);
  color: var(--color-text-tertiary);
  transition:
    background var(--duration-fast),
    color var(--duration-fast),
    border-color var(--duration-fast);
}

.footer__social-link:hover {
  background: rgba(245,166,35,0.12);
  color: var(--color-brand-primary);
  border-color: rgba(245,166,35,0.30);
}

/* Links */
.footer__links {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: var(--space-8);
}

.footer__col-title {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  color: var(--color-text-tertiary);
  letter-spacing: 0.10em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
}

.footer__col ul { display: flex; flex-direction: column; gap: var(--space-2); }

.footer__link {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  transition: color var(--duration-fast);
  text-decoration: none;
}
.footer__link:hover { color: var(--color-brand-primary); }

.footer__address {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  font-style: normal;
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
}

/* Bottom */
.footer__bottom {
  margin-top: var(--space-12);
  border-top: 1px solid var(--color-surface-divider);
  padding-block: var(--space-5);
}

.footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.footer__copy,
.footer__made {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
}
</style>
