---
/**
 * Breadcrumbs.astro — Accessible breadcrumb navigation + JSON-LD
 */
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Ruta de navegación">
  <ol class="breadcrumbs__list" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, index) => (
      <li
        class="breadcrumbs__item"
        itemprop="itemListElement"
        itemscope
        itemtype="https://schema.org/ListItem"
      >
        {item.href && index < items.length - 1 ? (
          <a href={item.href} class="breadcrumbs__link" itemprop="item">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span class="breadcrumbs__current" itemprop="name" aria-current="page">
            {item.label}
          </span>
        )}
        <meta itemprop="position" content={String(index + 1)} />
        {index < items.length - 1 && (
          <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
.breadcrumbs {
  padding-block: var(--space-4);
}

.breadcrumbs__list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-1);
  list-style: none;
}

.breadcrumbs__item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.breadcrumbs__link {
  font-size: var(--text-xs);
  font-weight: var(--fw-medium);
  color: var(--color-text-tertiary);
  letter-spacing: 0.02em;
  transition: color var(--duration-fast);
}

.breadcrumbs__link:hover {
  color: var(--color-brand-primary);
}

.breadcrumbs__sep {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  opacity: 0.5;
  user-select: none;
}

.breadcrumbs__current {
  font-size: var(--text-xs);
  font-weight: var(--fw-medium);
  color: var(--color-brand-primary);
  letter-spacing: 0.02em;
  /* Truncate long slugs on mobile */
  max-width: 24ch;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
</style>
