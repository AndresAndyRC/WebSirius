---
/**
 * Header.astro — Primary site header with logo + navigation
 */
const navLinks: { label: string; href: string; active?: boolean }[] = [
  { label: 'Colecciones', href: '/colecciones' },
  { label: 'Blog',        href: '/blog' },
  { label: 'FAQs',        href: '/faqs' },
  { label: 'Contacto',    href: '/contacto' },
];
---

<header class="header glass" role="banner">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="SIRIUS — Ir al inicio">
      <span class="header__logo-mark" aria-hidden="true">✦</span>
      <span class="header__logo-text font-display">SIRIUS</span>
      <span class="header__logo-tagline">Iluminación</span>
    </a>

    <!-- Desktop navigation -->
    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="header__nav-list" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`header__nav-link ${link.active ? 'header__nav-link--active' : ''}`}
              {...(link.active ? { 'aria-current': 'page' } : {})}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <div class="header__actions">
      <a
        href="/colecciones/paneles-led-redondos"
        class="btn btn--primary header__cta"
        aria-label="Ver catálogo de productos SIRIUS"
      >
        Ver Catálogo
      </a>

      <!-- Mobile menu toggle -->
      <button
        class="header__menu-btn"
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Abrir menú de navegación"
      >
        <span class="header__menu-bar"></span>
        <span class="header__menu-bar"></span>
        <span class="header__menu-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile navigation -->
  <nav id="mobile-nav" class="header__mobile-nav" aria-label="Menú móvil" hidden>
    <ul class="header__mobile-list" role="list">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="header__mobile-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/colecciones/paneles-led-redondos"
          class="btn btn--primary header__mobile-cta"
        >
          Ver Catálogo →
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav    = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    nav?.toggleAttribute('hidden');
    toggle.classList.toggle('is-open');
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      toggle.setAttribute('aria-expanded', 'false');
      nav?.setAttribute('hidden', '');
      toggle.classList.remove('is-open');
    }
  });
</script>

<style>
.header {
  position: sticky;
  top: var(--topbar-h);
  z-index: var(--z-sticky);
  height: var(--header-h);
  border-bottom: 1px solid var(--color-surface-border);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  gap: var(--space-6);
}

/* Logo */
.header__logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.header__logo-mark {
  font-size: var(--text-xl);
  color: var(--color-brand-primary);
  line-height: 1;
}

.header__logo-text {
  font-size: var(--text-xl);
  font-weight: var(--fw-bold);
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
}

.header__logo-tagline {
  font-size: var(--text-xs);
  font-weight: var(--fw-medium);
  color: var(--color-text-tertiary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  align-self: flex-end;
  padding-bottom: 2px;
}

/* Nav */
.header__nav { flex: 1; display: flex; justify-content: center; }

.header__nav-list {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.header__nav-link {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition:
    color var(--duration-fast),
    background var(--duration-fast);
  position: relative;
}

.header__nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: var(--space-3);
  right: var(--space-3);
  height: 2px;
  background: var(--color-brand-primary);
  border-radius: 1px;
  transform: scaleX(0);
  transition: transform var(--duration-normal) var(--ease-out-expo);
}

.header__nav-link:hover {
  color: var(--color-text-primary);
  background: rgba(255,255,255,0.04);
}

.header__nav-link:hover::after,
.header__nav-link--active::after {
  transform: scaleX(1);
}

.header__nav-link--active {
  color: var(--color-brand-primary);
}

/* Actions */
.header__actions { display: flex; align-items: center; gap: var(--space-3); }

.header__cta { display: none; }
@media (min-width: 640px) { .header__cta { display: inline-flex; } }

/* Hamburger */
.header__menu-btn {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 24px;
  height: 18px;
  padding: 0;
  background: none;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
}

@media (min-width: 900px) { .header__menu-btn { display: none; } }
@media (min-width: 900px) { .header__nav { display: flex; } }
@media (max-width: 899px) { .header__nav { display: none; } }

.header__menu-bar {
  display: block;
  width: 100%;
  height: 2px;
  background: var(--color-text-secondary);
  border-radius: 2px;
  transition:
    transform var(--duration-normal) var(--ease-out-expo),
    opacity   var(--duration-fast);
}

.header__menu-btn.is-open .header__menu-bar:nth-child(1) {
  transform: translateY(8px) rotate(45deg);
}
.header__menu-btn.is-open .header__menu-bar:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}
.header__menu-btn.is-open .header__menu-bar:nth-child(3) {
  transform: translateY(-8px) rotate(-45deg);
}

/* Mobile nav */
.header__mobile-nav {
  background: var(--color-surface-raised);
  border-top: 1px solid var(--color-surface-border);
  padding: var(--space-4);
}

.header__mobile-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.header__mobile-link {
  display: block;
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-base);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: background var(--duration-fast), color var(--duration-fast);
}

.header__mobile-link:hover {
  background: var(--color-surface-overlay);
  color: var(--color-text-primary);
}

.header__mobile-cta {
  margin-top: var(--space-2);
  width: 100%;
  justify-content: center;
}
</style>
