---
/**
 * TableOfContents.astro — Sticky sidebar table of contents
 * Highlights the current section using IntersectionObserver
 */
export interface TocItem {
  id: string;
  label: string;
  level?: number;
}

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<nav class="toc" aria-label="Tabla de contenidos">
  <p class="toc__title" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
      <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
    </svg>
    En este artículo
  </p>

  <ol class="toc__list" role="list">
    {items.map(item => (
      <li class={`toc__item toc__item--level-${item.level ?? 2}`}>
        <a
          href={`#${item.id}`}
          class="toc__link"
          data-toc-id={item.id}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ol>

  <div class="toc__progress" aria-hidden="true">
    <div class="toc__progress-bar" id="toc-progress-bar"></div>
  </div>
</nav>

<script>
  // Highlight active section + reading progress
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
  const progressBar = document.getElementById('toc-progress-bar');

  // IntersectionObserver for active heading
  if (links.length > 0) {
    const headingEls = Array.from(links).map(l =>
      document.getElementById(l.dataset.tocId ?? ''),
    ).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = document.querySelector<HTMLAnchorElement>(`[data-toc-id="${id}"]`);
          if (link) {
            link.classList.toggle('toc__link--active', entry.isIntersecting);
          }
        });
      },
      {
        rootMargin: '-20% 0px -70% 0px',
        threshold: 0,
      },
    );

    headingEls.forEach(el => observer.observe(el));
  }

  // Reading progress bar
  if (progressBar) {
    const article = document.getElementById('article-content');
    const update = () => {
      if (!article) return;
      const { top, height } = article.getBoundingClientRect();
      const progress = Math.min(1, Math.max(0, (window.innerHeight - top) / (height + window.innerHeight)));
      progressBar.style.width = `${progress * 100}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>

<style>
.toc {
  background: var(--color-surface-raised);
  border: 1px solid var(--color-surface-border);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  position: relative;
  overflow: hidden;
}

.toc__title {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--color-surface-divider);
}

.toc__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.toc__item--level-3 .toc__link {
  padding-left: var(--space-4);
  font-size: var(--text-xs);
}

.toc__link {
  display: block;
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
  border-radius: var(--radius-md);
  transition:
    color var(--duration-fast),
    background var(--duration-fast);
  border-left: 2px solid transparent;
  line-height: var(--lh-snug);
}

.toc__link:hover {
  color: var(--color-text-primary);
  background: rgba(255,255,255,0.04);
}

.toc__link--active {
  color: var(--color-brand-primary);
  background: rgba(245,166,35,0.08);
  border-left-color: var(--color-brand-primary);
  font-weight: var(--fw-medium);
}

/* Progress bar */
.toc__progress {
  margin-top: var(--space-5);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-surface-divider);
  height: 3px;
  background: var(--color-surface-overlay);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.toc__progress-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--color-brand-primary), var(--color-brand-accent));
  border-radius: var(--radius-full);
  transition: width 100ms linear;
}
</style>
