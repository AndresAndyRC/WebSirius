---
/**
 * CTACard.astro — Inline product call-to-action card within article prose
 * Used for warm/neutral/cool light temperature CTAs
 */
export interface Props {
  type: 'warm' | 'neutral' | 'cool' | 'adjustable';
  title: string;
  description: string;
  href: string;
  cta: string;
  icon: string;
}

const { type, title, description, href, cta, icon } = Astro.props;

const typeConfig = {
  warm:       { label: 'Luz Cálida',    temp: '2700K – 3500K', border: 'rgba(255,154,62,0.30)',  bg: 'rgba(255,154,62,0.06)',  color: 'var(--color-warm)'   },
  neutral:    { label: 'Luz Neutra',    temp: '4000K – 4500K', border: 'rgba(200,220,255,0.25)', bg: 'rgba(200,220,255,0.05)', color: '#C8DCFF'              },
  cool:       { label: 'Luz Blanca',    temp: '5000K – 6500K', border: 'rgba(126,200,255,0.30)', bg: 'rgba(126,200,255,0.06)', color: 'var(--color-cool)'   },
  adjustable: { label: 'CCT Ajustable', temp: '2700K – 6500K', border: 'rgba(245,166,35,0.40)',  bg: 'rgba(245,166,35,0.08)',  color: 'var(--color-brand-primary)' },
} as const;

const cfg = typeConfig[type];
---

<aside
  class="cta-card"
  style={`--cta-border: ${cfg.border}; --cta-bg: ${cfg.bg}; --cta-color: ${cfg.color};`}
  aria-label={`Producto recomendado: ${title}`}
>
  <div class="cta-card__icon-wrap" aria-hidden="true">
    {icon}
  </div>

  <div class="cta-card__body">
    <div class="cta-card__meta">
      <span class="cta-card__label">{cfg.label}</span>
      <span class="cta-card__temp">{cfg.temp}</span>
    </div>
    <p class="cta-card__title">{title}</p>
    <p class="cta-card__desc">{description}</p>
  </div>

  <a href={href} class="cta-card__btn btn btn--primary" aria-label={cta}>
    {cta}
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</aside>

<style>
.cta-card {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-5);
  background: var(--cta-bg);
  border: 1px solid var(--cta-border);
  border-left: 3px solid var(--cta-color);
  border-radius: var(--radius-lg);
  margin-block: var(--space-6);
  flex-wrap: wrap;
  transition: transform var(--duration-normal) var(--ease-out-expo);
}

.cta-card:hover {
  transform: translateY(-2px);
}

.cta-card__icon-wrap {
  font-size: 2rem;
  flex-shrink: 0;
  line-height: 1;
}

.cta-card__body {
  flex: 1;
  min-width: 180px;
}

.cta-card__meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-1);
}

.cta-card__label {
  font-size: var(--text-xs);
  font-weight: var(--fw-bold);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--cta-color);
}

.cta-card__temp {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.cta-card__title {
  font-size: var(--text-base);
  font-weight: var(--fw-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-1);
  font-family: var(--font-display);
}

.cta-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: var(--lh-snug);
}

.cta-card__btn {
  white-space: nowrap;
  flex-shrink: 0;
}
</style>
