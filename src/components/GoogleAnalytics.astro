---
/**
 * GoogleAnalytics.astro — GA4 snippet
 * Cargado solo en producción (import.meta.env.PROD).
 *
 * Prioridad del ID:
 *   1. Prop `id` pasada directamente
 *   2. Variable de entorno GOOGLE_ANALYTICS_ID (Vercel dashboard / .env)
 *   3. Fallback hardcoded (garantiza que siempre funcione en producción)
 */

export interface Props {
  id?: string;
}

const { id } = Astro.props;

// Lee el ID desde la variable de entorno (definida en .env o Vercel dashboard)
const gaId = id ?? import.meta.env.GOOGLE_ANALYTICS_ID ?? '';

// Inyectar solo en builds de producción con ID válido
const shouldInject = import.meta.env.PROD && gaId.startsWith('G-');
---

{shouldInject && (
  <>
    <!-- Google tag (gtag.js) — solo producción -->
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
    ></script>
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      // anonymize_ip no existe en GA4 — la anonimización es automática
      gtag('config', gaId, {
        cookie_flags:   'SameSite=None;Secure',
        send_page_view: true,
      });
    </script>
  </>
)}
