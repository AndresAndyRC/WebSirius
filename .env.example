# ── Copia este archivo como .env para desarrollo local ───────
# NO subas .env al repositorio (.gitignore ya lo excluye)
# Configura estas mismas variables en:
#   · Vercel   → tu proyecto → Settings → Environment Variables
#   · GitHub   → Settings → Secrets → Actions

# Google Analytics 4 — Measurement ID
# Obtén tu ID en: analytics.google.com → Admin → Data Streams
GOOGLE_ANALYTICS_ID=G-TB3KKLD8HH

# URL pública del sitio (sin trailing slash)
PUBLIC_SITE_URL=https://siriuscol.com
