# ── Copia este archivo como .env para desarrollo local ───────
# NO subas .env al repositorio (.gitignore ya lo excluye)
# Configura estas mismas variables en:
#   · Vercel   → tu proyecto → Settings → Environment Variables
#   · GitHub   → Settings → Secrets → Actions

# Google Analytics 4 — Measurement ID
# Obtén tu ID en: analytics.google.com → Admin → Data Streams
GOOGLE_ANALYTICS_ID=G-TB3KKLD8HH

# URL pública del sitio (sin trailing slash)
PUBLIC_SITE_URL=https://web-sirius.vercel.app

# URL de Eventos en Wompi Panel: Aquí debes colocar en el recuadro "URL de eventos": https://tudominio.com/api/webhooks/wompi

# 1. De la sección "Llaves del API para integración técnica" en el Wompi Dashboard
WOMPI_PUBLIC_KEY="pub_prod_..." # Tu llave pública

# 2. De la sección "Secretos para integración técnica"
WOMPI_INTEGRITY_SECRET="aquí_el_secreto_de_integridad_revelado" 

# 3. De la sección "Secretos para integración técnica"
WOMPI_EVENT_SECRET="aquí_el_secreto_de_eventos_revelado"

